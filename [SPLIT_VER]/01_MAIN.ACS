function void getVersion (void)
{
    str gotWest = "0";
    str gotEast = "0";
    str gotSouth = "0";
    if (GetCvar("diskEast")) {vRpgVersion++; gotEast = "E";}
    if (GetCvar("diskWest")) {vRpgVersion++; gotWest = "W";}
    if (GetCvar("diskSouth")) {vRpgVersion++; gotSouth = "S";}
    if (GetCvar("diskDebug")) {vRpgVersion++;}
    strRpgVersion = StrParam(s:"\c[FamiGrey]Ver0.",d:vRpgVersion,s:(GetCvar("diskDebug") ? "\c[FamiRed]DEBUG" : strParam(s:gotWest,s:gotSouth,s:gotEast)));
}

function bool diskCheck (int diskType)
{
    bool diskBool = 0;
    if (diskType == DISK_EAST) {diskBool = GetCvar("diskEast");}
    if (diskType == DISK_WEST) {diskBool = GetCvar("diskWest");}
    if (diskType == DISK_SOUTH) {diskBool = GetCvar("diskSouth");}
    if (diskType == DISK_ATTACKS) {diskBool = GetCvar("diskAttack");}
    if (diskType == DISK_ITEMS) {diskBool = GetCvar("diskItems");}
    if (diskType == DISK_DEBUG) {diskBool = GetCvar("diskDebug");}
    return diskBool;
}

function void setRes (void)
{
    SetHudSize(320,256,TRUE);
}

function void draw (str fontname, str string, int zone, int posX, int posY)
{
    setRes();
    SetFont(fontname);
    HudMessage(s:string;HUDMSG_PLAIN|HUDMSG_LAYER_OVERHUD,zone,CR_UNTRANSLATED,posX,posY,0);
}

function void clear (int zone)
{
    HudMessage(s:"";HUDMSG_PLAIN,zone,CR_UNTRANSLATED,0.0,0.0,1873);
}

function void clearAll (void)
{
    clear(ZONE_BG);
    clear(ZONE_SPRITE1);
    clear(ZONE_SPRITE2);
    clear(ZONE_SPRITE3);
    clear(ZONE_ROOM);
    clear(ZONE_ELPH);
    clear(UI_BOX);
    clear(UI_PORTBOX);
    clear(UI_TEXT);
    clear(UI_PORT);
    clear(UI_HUDFACE);
    clear(UI_HUDKEY1);
    clear(UI_HUDKEY2);
    clear(UI_HUDKEY3);
    clear(UI_HUDKEY3);
    clear(UI_HUDSKATE);
    clear(UI_HUDBAND);
    clear(UI_HUDBOOK);
    clear(UI_HUDROOMNAME);
    clear(UI_HUDBAR);
    clear(UI_MENU);
    clear(UI_MENUTEXT);
    clear(UI_MENUINFO);
    clear(UI_MENUSELECTOR);
    clear(BATTLE_SLOT);
}

function void drawHud (void)
{
    draw("RPGHUD","A",UI_HUDBAR,0.1,0.1);
    //draw(vExpression,"A",UI_HUDFACE,0.1,0.1);
    draw("UNSCII",strParam(s:"MIND: ",i:(vHP < 0 ? 0 : vHP),s:"/40\nGOLD: ",i:vGold,s:"\n",s:sonataTimeDisplay),UI_HUDROOMNAME,4.1,4.1);
    if (key1Got) {draw("RPGKEY1","A",UI_HUDKEY1,235.1,7.1);}
    if (key2Got) {draw("RPGKEY2","A",UI_HUDKEY2,265.1,7.1);}
    if (key3Got) {draw("RPGKEY3","A",UI_HUDKEY3,295.1,7.1);}
    if (altboss1Clear) {draw("RPGSKATE","A",UI_HUDSKATE,205.1,7.1);}
    if (altboss2Clear) {draw((vPowerSpeed == 0 ? "RPGBANDP" : "RPGBANDS"),"A",UI_HUDBAND,175.1,7.1);}
    if (vHasBook) {draw("RPGBOOK","A",UI_HUDBOOK,145.1,7.1);}
}

function void drawSprite (int tile, str sprite, int zone)
{
    tile = tile;
    int tileX = tile%20;
    int tileY = tile/20;
    draw(SPRITE,"A",zone,0.1+((tileX*16)<<16),32.1+((tileY*16)<<16));
}

function void drawElph (void)
{
    if (Timer()%6 == 0)
    {
        vAnim = !vAnim;
    }

    draw(strParam(s:"RPGELPH",i:vAnim+1),"A",ZONE_ELPH,((vPosX*16)+(vTweenX*TWEEN_MULT)<<16)+0.1,((vPosY*16)+(vTweenY*TWEEN_MULT)<<16)+32.1);
}

function void interact (int checkXY, int checkRoom)
{
    // general cases
    for (int i = 0 ; i < INTERACTION_ARRAY_SIZE/4 ; i++)
    {
        if (checkRoom == interactionDB[i*4])
        {
            if (checkXY == interactionDB[(i*4)+1])
            {
                if (interactionDB[(i*4)+3] != 0)
                {
                    if (vteleportBufferTime <= 0)
                    {
                        if (checkRoom != ROOM_E || GetCvar("diskDebug") == 1)
                        {
                            ACS_NamedExecute("roomChange",0,interactionDB[(i*4)+2],interactionDB[(i*4)+3]);
                            ACS_NamedExecute("teleportBuffer",0);
                        }
                    }
                    break;
                }
                else
                {
                    if (interactionDB[(i*4)+2] == INT_MSX) {vHasBomb = 1; vHasPotion = 1;}
                    ACS_NamedExecute("interactObject",0,interactionDB[(i*4)+2]);
                    break;
                }
            }
        }
    }

    // special cases
    switch (checkRoom)
    {
        case ROOM_HOMEMOON:
        switch (checkXY)
        {
            case EXIT_HOMEMOON_EXIT:
            ACS_NamedExecute("roomChange",0,ROOM_HOMEHALL,ENTER_HOMEHALL_FROMMOON);
            ACS_NamedTerminate("sanity",0);
            break;
        }
    }
}

function void textBox (bool drawClear, int drawType, str portType)
{
    if (drawClear)
    {
        vHasControl = 0;
        if (drawType == INT_OBJ)
        {
            draw("RPGTBOX","A",UI_BOX,48.1,144.1);
        }
        if (drawType == INT_NPC)
        {
            draw("RPGTBOX","A",UI_BOX,68.1,144.1);
            draw("RPGPBOX","A",UI_PORTBOX,28.1,152.1);
            draw(portType,"A",UI_PORT,36.1,160.1);
        }
    }
    else
    {
        vHasControl = 1;
        clear(UI_TEXT);
        clear(UI_BOX);
        clear(UI_PORTBOX);
        clear(UI_PORT);
    }
}

function void moveElph (int direction)
{
    getElphReal();

    if (vHasControl)
    {
        Switch (direction)
        {
            Case 1:
            vWishPos = vRealPos+1;
            if (screenDB[vCurrentScreen][vWishPos] == 0) {vTriedUse = 1;}
            if (screenDB[vCurrentScreen][vWishPos] == 1 || vPosX == 19 || GetCvar("debugMode")) {vPosX++; vTweenX -= TWEEN_SPEED; vTriedUse = 0; PlaySound(0,(vStepCount%2 == 0 ? vStep1 : vStep2),4);}
            if (screenDB[vCurrentScreen][vWishPos] == 2) {interact(vWishPos,vCurrentScreen); vTriedUse = 2;}
            Break;

            Case 2:
            vWishPos = vRealPos-1;
            if (screenDB[vCurrentScreen][vWishPos] == 0) {vTriedUse = 1;}
            if (screenDB[vCurrentScreen][vWishPos] == 1 || vPosX == 0 || GetCvar("debugMode")) {vPosX--; vTweenX += TWEEN_SPEED; vTriedUse = 0; PlaySound(0,(vStepCount%2 == 0 ? vStep1 : vStep2),4);}
            if (screenDB[vCurrentScreen][vWishPos] == 2) {interact(vWishPos,vCurrentScreen); vTriedUse = 2;}
            Break;

            Case 3:
            vWishPos = vRealPos+20;
            if (screenDB[vCurrentScreen][vWishPos] == 0) {vTriedUse = 1;}
            if (screenDB[vCurrentScreen][vWishPos] == 1 || vPosY == 13 || GetCvar("debugMode")) {vPosY++; vTweenY -= TWEEN_SPEED; vTriedUse = 0; PlaySound(0,(vStepCount%2 == 0 ? vStep1 : vStep2),4);}
            if (screenDB[vCurrentScreen][vWishPos] == 2) {interact(vWishPos,vCurrentScreen); vTriedUse = 2;}
            Break;

            Case 4:
            vWishPos = vRealPos-20;
            if (screenDB[vCurrentScreen][vWishPos] == 0) {vTriedUse = 1;}
            if (screenDB[vCurrentScreen][vWishPos] == 1 || vPosY == 0 || GetCvar("debugMode")) {vPosY--; vTweenY += TWEEN_SPEED; vTriedUse = 0; PlaySound(0,(vStepCount%2 == 0 ? vStep1 : vStep2),4);}
            if (screenDB[vCurrentScreen][vWishPos] == 2) {interact(vWishPos,vCurrentScreen); vTriedUse = 2;}
            Break;
        }

        if (vTriedUse == 0 && vPosX < 18 && vPosX > 1 && vPosY < 12 && vPosY > 1)
        {
            vStepCount++;
            vStepCount = vStepCount%128;
        }

		if (vStepCount > 116 && getRNG()%4 == 0 && vPosX < 19 && vPosX > 0 && vPosY < 13 && vPosY > 0 && vTrieduse == 0)
		{
		    int eCheck = areaEncounters[getRNG()%2];
			if ((echeck != 99 || (eCheck == bENEMY_ATLAS && !atlasDone)) && battlesOn)
			{
				ACS_NamedExecute("b_initBattle",0,eCheck);
			}
		}

        if (debugger)
        {
            if (vTriedUse == 2) {debugInteract = strparam(s:"R", i:vCurrentScreen, s:" T", i:vWishPos);}
            else if (vTriedUse == 1) {debugInteract = "WALL";}
            else {debugInteract = "NONE";}
        }

	if (vPosX > 19 && vCurrentScreen < 143) {ACS_NamedExecute("roomChange",0,vCurrentScreen+1,vPosY*20);}
	if (vPosX < 0 && vCurrentScreen > 0) {ACS_NamedExecute("roomChange",0,vCurrentScreen-1,(vPosY*20)+19);}
	if (vPosY > 13 && vCurrentScreen < 131) {ACS_NamedExecute("roomChange",0,vCurrentScreen+12,vPosX);}
    if (vPosY < 0 && vCurrentScreen > 11) {ACS_NamedExecute("roomChange",0,vCurrentScreen-12,vPosX+260);}
    }

    getElphReal();
    if (GetCvar("debugMode")) {getElphReal(); log(s:"R",i:vCurrentScreen,s:" T",i:vRealPos);}
    if (!bSafetyCheck) {drawElph();}

    // ITEM COLLECTION, OTHER SPECIAL CASES
    if (vCurrentScreen == ROOM_CROSSING && vWishPos == OBJ_CROSSING_SHOP)
    {
        ACS_NamedExecute("shopping",0);
        PlaySound(0,"RPGRUN",2);
    }
    if (vCurrentScreen == ROOM_STAR_MAZE_KEY)
    {
        if (vHasBook == 0 && (vPosX + (vPosY*20)) == sprite1At)
        {
            clear(ZONE_SPRITE1); vHasBook = 1; AmbientSound("RPGKEY",127); drawHUD();
        }
    }
    if (vCurrentScreen == ROOM_PAINFRAME)
    {
        if (key2Got == 0 && (vPosX + (vPosY*20)) == sprite1At)
        {
            clear(ZONE_SPRITE1); key2Got = 1; AmbientSound("RPGKEY",127); drawHUD();
        }
    }
    if (vCurrentScreen == ROOM_TOWERBASEMENT)
    {
        if (key3Got == 0 && (vPosX + (vPosY*20)) == sprite1At)
        {
            clear(ZONE_SPRITE1); key3Got = 1; AmbientSound("RPGKEY",127); drawHUD();
        }
    }
    if (vCurrentScreen == ROOM_POSTGUTS2 && key1Got == 0 && (vPosX + (vPosY*20)) == sprite1At) {clear(ZONE_SPRITE1); key1Got = 1; AmbientSound("RPGKEY",127); drawHUD();}
    if (vCurrentScreen == ROOM_FLY && altBoss2Clear == 0 && vPosY < 7) {ACS_NamedExecute("b_initBattle",0,bENEMY_FLY);}
    if (vCurrentScreen == ROOM_KEYS)
    {
        if (key1Got == 1 && unlocked1 == 0 && vWishPos == 122)
        {
            ACS_NamedExecuteAlways("keyUnlock",0,122,ZONE_SPRITE1);
            clear(UI_HUDKEY1);
            unlocked1 = 1;
            key1Got = 0;
        }
        if (key2Got == 1 && unlocked2 == 0 && vWishPos == 49)
        {
            ACS_NamedExecuteAlways("keyUnlock",0,49,ZONE_SPRITE2);
            clear(UI_HUDKEY2);
            unlocked2 = 1;
            key2Got = 0;
        }
        if (key3Got == 1 && unlocked3 == 0 && vWishPos == 136)
        {
            ACS_NamedExecuteAlways("keyUnlock",0,136,ZONE_SPRITE3);
            clear(UI_HUDKEY3);
            unlocked3 = 1;
            key3Got = 0;
        }
    }
}


// unused disk flipping routine
script "diskSide" (int entry)
{
    bool hadControl = 0;
    if (vHasControl) {hadControl = 1; vHasControl = 0;}
    SetMusic("");
    clearAll();
    Delay(5);
    if (diskSide != loadArray[entry+2])
    {
        draw("UNSCII",strParam(s:"SET SIDE ",s:(loadArray[entry+2] == 0 ? "A" : "B")),50,160.0,112.2);
        while (diskSide != loadArray[entry+2])
        {
            Delay(15);
        }
    }
    clearAll();
    Delay(5);
    AmbientSound("DISKREAD",127);
    draw("UNSCII","WAIT A MOMENT",50,160.0,112.2);
    Delay(125);
    clearAll();
    Delay(10);
    if (hadControl) {hadControl = 0; vHasControl = 1;}
}

script "keyUnlock" (int tile, int zone)
{
    PlaySound(0,"RPGBMEL",1);
    drawSprite(tile-21,"RPGBFX4",zone);Delay(2);
    drawSprite(tile-42,"RPGBFX5",zone);Delay(2);
    drawSprite(tile-42,"RPGBFX6",zone);Delay(3);
    drawSprite(tile-42,"RPGBFX7",zone);Delay(3);
    clear(zone);
    drawHud();

    if (unlocked1 && unlocked2 && unlocked3)
    {
        ACS_NamedExecute("roomChange",0,ROOM_KEYS_OPEN,vRealPos);
    }
}

function void getElphReal (void)
{
    vRealPos = vPosX + (vPosY*20);
}

function void getElphXY (void)
{
    vPosX = vRealPos%20;
    vPosY = vRealPos/20;
}

function void changeBGM (str musicName, int unused, bool remember)
{
    if (musicName == BGM_NONE || (vCurrentScreen == ROOM_PAINFRAME && boss2Clear)|| (vCurrentScreen == ROOM_STAR_MAZE_D && boss4clear))
    {
        SetMusic("");
    }
    else
    {
        SetMusic("D_SNT",musicName);
    }
	if (remember)
	{
		vLastMusic = musicName;
		vLastMusicFile = unused;
	}
}

function void drawRoom(bool buffered)
{
    if (!buffered)
    {
    // CHECK BOSS 1 CLEAR
    if (vCurrentScreen == ROOM_PROTECTORS && boss1Clear) {vCurrentScreen = ROOM_POSTGUTS;}
    if (vCurrentScreen == ROOM_STAR_MAZE_D && boss4Clear) {vCurrentScreen = ROOM_STAR_MAZE_POST;}
    if (vCurrentScreen == ROOM_KEYS && unlocked1 && unlocked2 && unlocked3) {vCurrentScreen = ROOM_KEYS_OPEN;}

    // SPRITES
    switch (vCurrentScreen)
    {
        case ROOM_POSTGUTS2:
        if (key1Got == 0 && unlocked1 == 0) {drawSprite(130,"RPGKEY1",ZONE_SPRITE1); sprite1At = 130;}
        break;

        case ROOM_STAR_MAZE_KEY:
        if (vHasBook == 0) {drawSprite(149,"RPGBOOK",ZONE_SPRITE1); sprite1At = 149;}
        break;

        case ROOM_LTQ:
        drawSprite(OBJ_LTQ,"RPGLTQS",ZONE_SPRITE1); sprite1At = OBJ_LTQ;
        break;

        case 120:
        drawSprite(72,"RPGTUNLS",ZONE_SPRITE1); sprite1At = 72;
        break;

        case ROOM_STAR_MAZE_D:
        if (!boss4Clear) {drawSprite(89,"RPGEYE",ZONE_SPRITE1); sprite1At = 89;}
        break;

        case ROOM_TOWERBASEMENT:
        if (boss3Clear && key3Got == 0 && unlocked3 == 0) {drawSprite(170,"RPGKEY3",ZONE_SPRITE1); sprite1At = 170;}
        break;

        case ROOM_PAINFRAME:
        if (!boss2Clear) {drawSprite(127,"RPGCOMP1",ZONE_SPRITE1); sprite1At = 127;}
        else if (boss2Clear && key2Got == 0 && unlocked2 == 0) {drawSprite(125,"RPGKEY2",ZONE_SPRITE1); sprite1At = 125;}
        break;

        case ROOM_KEYS:
        if (unlocked1 == 0) {drawSprite(122,"RPGKEYH1",ZONE_SPRITE1); sprite1At = 130;}
        if (unlocked2 == 0) {drawSprite(49,"RPGKEYH2",ZONE_SPRITE2); sprite2At = 130;}
        if (unlocked3 == 0) {drawSprite(136,"RPGKEYH3",ZONE_SPRITE3); sprite3At = 130;}
        break;

        default:
        sprite1At = 0;
        sprite2At = 0;
        sprite3At = 0;
    }

    vSanityTimer = 0;
    ACS_NamedTerminate("sanity",0);
    debugMessage = "";
    debugMessage2 = "";
    debugMessage3 = "";

    // special cases
    switch (vCurrentScreen)
    {
        case 111:
        case 112:
        case ROOM_PAINFRAME:
        case ROOM_SOUTH_COMPUTER:
            draw("SBG004","A",ZONE_BG,160.0,144.0);
            break;

        case ROOM_KEYS:
        case ROOM_KEYS_OPEN:
        case ROOM_STAR_MAZE_A:
        case ROOM_STAR_MAZE_B:
        case ROOM_STAR_MAZE_C:
        case ROOM_STAR_MAZE_D:
        case ROOM_STAR_MAZE_KEY:
        case ROOM_STAR_MAZE_POST:
            draw("SBG003","A",ZONE_BG,160.0,144.0);
            break;

        case ROOM_WEST_GOINGDOWN:
        case ROOM_HOMEOUTSIDE:
        case ROOM_CROSSING:
        case ROOM_0X3E:
        case ROOM_0X40:
        case ROOM_0X4B:
        case ROOM_WESTWARD:
        case ROOM_EASTWARD:
        case ROOM_SOUTHBOUND:
            draw("SBG001","A",ZONE_BG,160.0,144.0);
            break;

        case 65:
        case 66:
        case 77:
        case 78:
        case 90:
            draw("SBG002","A",ZONE_BG,160.0,144.0);
            break;

        case ROOM_HOMEELPH:
            break;

        case ROOM_HOMEHALL:
            break;
    }

    // room drawing
    ACS_NamedExecute("areaSwitcher",0);
    draw(StrParam(s:"_SRM",i:vCurrentScreen),"A",ZONE_ROOM,160.0,144.0);
    drawHud();
    }

    else
    {
        setRes();
        SetFont(StrParam(s:"_SRM",i:vCurrentScreen));
        HudMessage(s:"A";HUDMSG_PLAIN,ZONE_ROOM,CR_UNTRANSLATED,160.0,-144.0,1873);
    }
}

script "titleMenu" (void)
{
    reInit();
    ACS_NamedTerminate("sonataTimer",0);
    changeBGM(BGM_NONE,2,TRUE);
    setRes();
    getVersion();
    draw("RPGBLSC1","A",50,160.0,128.0);
    Delay(4);
    draw("RPGBLSC2","A",50,160.0,128.0+random(-64,64));
    Delay(1);
    draw("RPGBLSC2","A",50,160.0,128.0+random(-128,128));
    Delay(1);
    Clear(50);
    Delay(10);

    if (!booted)
    {
        changeBGM(BGM_DISK,2,TRUE);
        draw("RPGDD1","A",50,160.0,128.0); Delay(3);
        draw("RPGDD2","A",50,160.0,128.0); Delay(3);
        draw("RPGDD3","A",50,160.0,128.0); Delay(3);
        draw("RPGDD4","A",50,160.0,128.0); Delay(3);
        draw("RPGDD5","A",50,160.0,128.0); Delay(1);
        draw("RPGDD4","A",50,160.0,128.0); Delay(1);
        draw("RPGDD5","A",50,160.0,128.0); Delay(1);
        draw("RPGDD4","A",50,160.0,128.0); Delay(1);
        draw("RPGDD5","A",50,160.0,128.0); Delay(1);
        draw("RPGDD4","A",50,160.0,128.0); Delay(25);
        draw("RPGDD3","A",50,160.0,128.0); Delay(5);
        draw("RPGDD2","A",50,160.0,128.0); Delay(5);
        draw("RPGDD1","A",50,160.0,128.0); Delay(5);
        clear(50);
        booted = 1;
        delay(30);

        debugmessage2 = "SCREEN_SELENESYSTEMS\n";
        draw("RPGHOWL","A",50,160.0,128.0);
        Delay(30);
        debugmessage2 = "";
        clear(50);
        Delay(30);
    }

    changeBGM(BGM_MOONLIGHT,1,TRUE);
    draw("RPGTITLE","A",50,160.0,60.1);
    draw("UNSCII",strRpgVersion,49,268.2,146.1);
    draw("UNSCII",strParam(s:"START\n",s:"COMBAT: ",s:(vHardMode == 2 ? "LIGHT" : (vHardMode == -1 ? "HYPER" : "NORMAL")),s:"\n",s:(GetCVar("diskDebug") ? "TEST MODE\n" : "\c[FamiGrey]...\n"),s:"QUIT\n"),48,104.1,168.1);
    draw("UNSCII",">",47,96.1,168.1);

    debugmessage2 = "SCREEN_TITLE\n";
    bool inMenu = 1;
    int menuOption = 0;

    while (inMenu)
    {
        if (inputDown && menuOption < 3)
        {
            menuOption++;
            PlaySound(0,"RPGMENUS",1);
            draw("UNSCII",">",47,96.1,168.1+((menuOption*8)<<16));
        }

        if (inputUp && menuOption > 0)
        {
            menuOption--;
            PlaySound(0,"RPGMENUS",1);
            draw("UNSCII",">",47,96.1,168.1+((menuOption*8)<<16));
        }

        if (inputUse)
        {
            switch (menuOption)
            {
                case 0:
                    if (diskCheck(DISK_EAST) || diskCheck(DISK_WEST) || diskCheck(DISK_SOUTH) || diskCheck(DISK_DEBUG)) {anyDisks = 1;}
                    PlaySound(0,"RPGMENUO",1);
                    inMenu = 0;
                break;

                case 1:
                    PlaySound(0,"RPGMENUO",1);
                    if (vHardMode == -1) {vHardMode = 2;}
                    else if (vHardMode == 2) {vHardMode = 0;}
                    else if (vHardMode == 0) {vHardMode = -1;}
                    draw("UNSCII",strParam(s:"START\n",s:"COMBAT: ",s:(vHardMode == 2 ? "LIGHT" : (vHardMode == -1 ? "HYPER" : "NORMAL")),s:"\n",s:(GetCVar("diskDebug") ? "TEST MODE\n" : "\c[FamiGrey]...\n"),s:"QUIT\n"),48,104.1,168.1);
                break;

                case 2:
                    if (GetCvar("diskDebug"))
                    {
                        clear(47);
                        clear(48);
                        clear(49);
                        clear(50);
                        PlaySound(0,"RPGMENUO",1);
                        ACS_NamedExecute("soundTest",0);
                        Terminate;
                    }
                break;

                case 3:
                    clear(47);
                    clear(48);
                    clear(49);
                    clear(50);
                    SetMusic("",0);
                    StopSound(0,7);
                    AmbientSound("FDSON",127);
                    Delay(10);
                    ChangeLevel("C2M0",0,CHANGELEVEL_NOINTERMISSION|CHANGELEVEL_RESETHEALTH|CHANGELEVEL_RESETINVENTORY,2);
                break;
            }
        }
        delay(1);
    }

    debugMessageInput = "";

    changeBGM(BGM_NONE,2,TRUE);
    clear(47);
    clear(48);
    clear(49);
    clear(50);


    drawRoom(1);
    Delay(20);
    drawHud();
    drawRoom(0);
    drawElph();
    drawTime = 1;
    vHasControl = 1;
    ACS_NamedExecute("HPtracker",0);
    ACS_NamedExecute("inputHandler",0);
    ACS_NamedExecute("tweenElph",0);
    ACS_NamedExecute("sonataTimer",0);
    ACS_NamedExecute("sonataTimeDsiplay",0);
}

script "soundTest" (void)
{
    changeBGM(BGM_NONE,2,TRUE);
    Delay(10);
    debugmessage = "";
    debugmessage2 = "";
    debugmessage3 = "";
    int stMusicFile = 0;
    int stMusicPattern = 0;
    int stSoundFile = 0;
    int stGraphic = 0;
    int stSelection = 1;
    bool stUpdate = 1;
    bool stUpdateHold = 0;

    draw("RPGCONSP","A",52,16.1,240.2);

    while (1)
    {
    if (inputUp)
    {
        stSelection--;
        stUpdate = 1;
        PlaySound(0,"RPGMENUS",1);
    }
    if (inputDown)
    {
        stSelection++;
        stUpdate = 1;
        PlaySound(0,"RPGMENUS",1);
    }

    if (inputLeft)
    {
        switch (stSelection)
        {
            case 0:
                stMusicFile--;
                stUpdate = 1;
                PlaySound(0,"RPGMENUS",1);
            break;

            case 1:
                stMusicPattern--;
                stUpdate = 1;
                PlaySound(0,"RPGMENUS",1);
            break;

            case 2:
                stSoundFile--;
                stUpdate = 1;
                PlaySound(0,"RPGMENUS",1);
            break;

            case 3:
                stGraphic--;
                stUpdate =1;
                PlaySound(0,"RPGMENUS",1);
            break;
        }
    }

    if (inputRight)
    {
        switch (stSelection)
        {
            case 0:
                stMusicFile++;
                stUpdate = 1;
                PlaySound(0,"RPGMENUS",1);
                break;

            case 1:
                stMusicPattern++;
                stUpdate = 1;
                PlaySound(0,"RPGMENUS",1);
            break;

            case 2:
                stSoundFile++;
                stUpdate = 1;
                PlaySound(0,"RPGMENUS",1);
            break;

            case 3:
                stGraphic++;
                stUpdate =1;
                PlaySound(0,"RPGMENUS",1);
            break;
        }
    }

    if (stGraphic < 0) {stGraphic = bgArrayTotal;}
    if (stGraphic > bgArrayTotal) {stGraphic = 0;}
    if (stSelection < 1) {stSelection = 1;}
    if (stSelection > 4) {stSelection = 4;}
    if (stMusicFile < 0) {stMusicFile = 0;}
    if (stMusicFile > 1) {stMusicFile = 1;}
    if (stMusicPattern < 0 ) {stMusicPattern = musicArray1Total-1;}
    if (stMusicPattern > musicArray1Total-1) {stMusicPattern = 0;}
    if (stSoundFile < 0) {stSoundFile = sfxArrayTotal-1;}
    if (stSoundFile > sfxArrayTotal-1) {stSoundFile = 0;}

    if (stUpdate)
    {
    draw
    (
        "UNSCII",
        strParam
        (
            s:(stSelection == 1 ? ">" : " "), s:"SONG\n",
            s:(stSelection == 2 ? ">" : " "), s:"SFX\n",
            s:(stSelection == 3 ? ">" : " "), s:"GFX\n",
            s:(stSelection == 4 ? ">" : " "), s:"EXIT "
        ),
        50,
        112.1,
        96.1
    );

    draw
    (
        "UNSCII",
        strParam
        (
            s:hexArray[stMusicPattern], s:"\n",
            s:"\c-",s:hexArray[stSoundFile],s:"\n",
            s:"\c-",s:hexArray[stGraphic],s:"\n"
        ),
        51,
        176.1,
        96.1
    );

    draw(bgArray[stGraphic],"A",54,160.0,128.0);

    if (stUpdateHold) {Delay(4); stUpdateHold = 0;}
    stUpdate = 0;
    }

    if (inputUse && (stSelection == 0 || stSelection == 1))
    {
        changeBGM(BGM_NONE,2,TRUE);
        Delay(5);
        changeBGM(musicArray1[stMusicPattern],1,TRUE);
    }
    if (inputUse && stSelection == 2)
    {
        changeBGM(BGM_NONE,2,TRUE);
        PlaySound(0,sfxArray[stSoundFile],1);
    }
    if (inputUse && stSelection == 4)
    {
        clear(50);
        clear(51);
        clear(52);
        clear(53);
        clear(54);
        changeBGM(BGM_NONE,2,TRUE);
        StopSound(0,1);
        PlaySound(0,"RPGMENUO",1);
        Delay(5);
        StopSound(0,1);
        AmbientSound("FDSON",127);
        ACS_NamedExecute("titleMenu",0);
        Terminate;
    }

    Delay(1);
    }
}

script "inputHandler" (void)
{
    while (1)
    {
        if (vHasControl)
        {
            if (inputRightHold)
            {
                debugMessageInput = StrParam(s:"R");
                moveElph(1);
                Delay(MOVE_DELAY);
            }
            if (inputLeftHold)
            {
                debugMessageInput = StrParam(s:"L");
                moveElph(2);
                Delay(MOVE_DELAY);
            }
            if (inputDownHold)
            {
                debugMessageInput = StrParam(s:"D");
                moveElph(3);
                Delay(MOVE_DELAY);
            }
            if (inputUpHold)
            {
                debugMessageInput = StrParam(s:"U");
                moveElph(4);
                Delay(MOVE_DELAY);
            }
        }
        if (inputUse && vHasControl)
            {
                ACS_NamedExecuteWait("inGameMenu",0);
            }
        debugMessageInput = StrParam(s:"-");
        Delay(1);
    }
}

script "tweenElph" (void)
{
    While (vTweenX != 0 || vTweenY != 0)
    {
        vTweening = 1;
        if (vTweenX < 0) {vTweenX+= 1;}
        if (vTweenX > 0) {vTweenX-= 1;}
        if (vTweenY < 0) {vTweenY+= 1;}
        if (vTweenY > 0) {vTweenY-= 1;}
        if (!bSafetyCheck) {drawElph();}
        Delay (1);
    }
    vTweening = 0;
    Delay (1);
    Restart;
}

script "interactObject" (int intArrayFetch)
{
    if (vHasControl)
    {
        setRes();

        if (intArrayFetch == INT_HOMEMOONBACK_BODY && altBoss1Clear)
        {
            intArrayFetch = INT_HOMEMOONBACK_BODY2;
        }

        if (intArrayFetch == INT_PAINFRAME && boss2Clear)
        {
            intArrayFetch = INT_PAINFRAME_POST;
        }

        if (intArrayFetch == INT_THEDARK && boss3Clear)
        {
            intArrayFetch = INT_THEDARK_POST;
        }

        if (intArrayFetch == INT_TUNNELER)
        {
            AmbientSound("RPGTUNL",127);
        }

        else
        {
            AmbientSound("RPGMENUO",127);
        }

        int type = intArrayFetch;

        debugMessage = strParam(s:"OBJI ", i:type, s:"\n");

        //textBox(1,objInteractions[type+1],objInteractions[type+2]);

        int lines = objInteractions[type+3];
        int i = 0;
        while (i < lines)
        {
            clear(UI_TEXT);
            clear(UI_BOX);
            clear(UI_PORTBOX);
            clear(UI_PORT);
            // if (objInteractions[type+i+7] != EXP_NORMAL)
            // {
            //     textBox(1,INT_NPC,objInteractions[type+i+7]);
            // }
            // else
            // {
            textBox(1,objInteractions[type+1],objInteractions[type+2]);
            // }
            SetHudClipRect(0,0,0,0,207,TRUE);
            draw
            (
                anyDisks ? "UNSCII" : "GLTEX",
                strParam
                (
                    s:"\c[FamiGrey]",
                    s:objInteractions[type+0],
                    s:"\cl\n",
                    s:objInteractions[type+i+4]
                ),
                UI_TEXT,
                (objInteractions[type+1] == INT_OBJ ? 56.1 : 76.1),
                152.1
            );
            SetHudClipRect(0,0,0,0,0);

            debugMessage2 = strParam(s:"T_LN ", i:lines, s:"\nC_LN ", i:i, s:"\n");

            while (1)
            {
                if (inputUse)
                {i++; break;}
                Delay(1);
                debugMessageInput = StrParam(s:"WAIT");
            }
            AmbientSound("RPGSLOT",127);
            debugMessageInput = "";
            Delay(1);
        }
        debugMessage = "";
        debugMessage2 = "";
        textBox(0,0,0);
        drawHud();

        // SPECIAL CONDITIONS

        switch (intArrayFetch)
        {
            case INT_THEDARK:
            vHasControl = 0;
            ACS_NamedExecute("b_initBattle",0,bENEMY_DARK);
            break;

            case INT_MOONGUARD:
            vHasControl = 0;
            ACS_NamedExecute("b_initBattle",0,bENEMY_MOONGUARD);
            break;

            case INT_PAINFRAME:
            vHasControl = 0;
            ACS_NamedExecute("b_initBattle",0,bENEMY_PAINFRAME);
            break;

            case INT_GUTS:
            vHasControl = 0;
            ACS_NamedExecute("b_initBattle",0,bENEMY_GUTS);
            break;

            case INT_GLOW_TV:
            ACS_NamedExecute("tvEvent",0);
            break;

            case INT_HOMEMOONBACK_BODY:
            vHasControl = 0;
            ACS_NamedExecute("b_initBattle",0,bENEMY_ELPH2);
            break;

            case INT_MOON_BOOK_R:
            ACS_NamedExecute("sanity", 0);
            break;
        }
    }
}

script "roomChange" (int moveToRoom, int moveToXY)
{
    vTweenX = 0;
    vTweenY = 0;
    vHasControl = 0;
    ACS_NamedTerminate("sanity",0);
    clear(ZONE_BG);
    clear(ZONE_ROOM);
    clear(ZONE_SPRITE1);
    clear(ZONE_SPRITE2);
    clear(ZONE_SPRITE3);
    clear(ZONE_ELPH);
    ACS_NamedSuspend("sonataTimer",0);
    drawRoom(1);
    Delay(15);

    // progression
    for (int i = 0; i < crossingProgressionCount; i++)
    {
        if (vCurrentScreen == crossingProgressionSource[i] &&
            moveToRoom == crossingProgressionTarget[i] &&
            diskCheck(crossingProgressionDisk[i]))
        {
            moveToRoom = crossingProgressionOK[i];
            break;
        }
    }

    vCurrentScreen = moveToRoom;
    vRealPos = moveToXY;
    vWishPos = movetoXY;

    getElphXY();
    drawRoom(0);
    ACS_NamedExecute("sonataTimer",0);
    drawElph();

    Delay(5);
    vHasControl = 1;
}

script "areaSwitcher" (void)
{
    for (int i = 0; i < bgmEncounterDBsize/5; i++)
    {
        if (vCurrentScreen == bgmEncounterDB[i*5])
        {
			areaEncounters[0] = bgmEncounterDB[(i*5)+2];
			areaEncounters[1] = bgmEncounterDB[(i*5)+3];
            battleMusicSwitch = bgmEncounterDB[(i*5)+4];
            if (vLastMusic != bgmEncounterDB[(i*5)+1])
            {
                changeBGM(BGM_NONE,2,TRUE); Delay(10);
                changeBGM(bgmEncounterDB[(i*5)+1],1,TRUE);
            }
        }
    }
}

script "inGameMenu" (void)
{
    SetMusicVolume(0.0);
    PlaySound(0,"RPGMENUO",1);
    int menuSelected = 0;
    setRes();
    vHasControl = 0;
    draw("RPGMENU","A",UI_MENU,208.1,176.1);
    SetFont("UNSCII");
    HudMessage(s:"\c[FamiGrey]SONATA\n\n\n\n\n\n\n\c[FamiGrey]v0.",i:vRpgVersion,s:(GetCvar("diskDebug") ? "D" : "A");HUDMSG_PLAIN,UI_MENUINFO,CR_UNTRANSLATED,224.1,176.1,0);
    draw("UNSCII",strParam(s:"RETURN\n",s:(vHasTeleport > 0 ? strParam(s:"TPORT\c[FamiGrey]x",i:vHasTeleport) : "\c[FamiGrey]..."),s:"\n",s:(vHasBook ? "PRAY" : "\c[FamiGrey]..."),s:"\n",s:(altBoss2Clear ? (vPowerSpeed ? "\c[FamiBlue]SPEED\n" : "\c[FamiRed]POWER\n") : "\c[FamiGrey]...\n\cl"),s:(GetCvar("diskDebug") ? "DEBUG\n" : "???\n"),s:"RESET"),UI_MENUTEXT,224.1,184.1);

    while (1)
    {
        if (inputDown && menuSelected < 5) {menuSelected++; PlaySound(0,"RPGMENUS",1);}
        if (inputUp && menuSelected > 0) {menuSelected--; PlaySound(0,"RPGMENUS",1);}
        if (inputUse)
        {
            if (menuSelected == 0)
            {
                SetMusicVolume(1.0);
                vHasControl = 1;
                clear(UI_MENU);
                clear(UI_MENUINFO);
                clear(UI_MENUTEXT);
                clear(UI_MENUSELECTOR);
                Terminate;
            }

            if (menuSelected == 1)
            {
                if (vHasTeleport > 0)
                {
                    vHasTeleport--;
                    PlaySound(0,"RPGTELE",1);
                    changeBGM(BGM_NONE,2,FALSE);
                    vLastScreen = vCurrentScreen;
                    vCurrentScreen = ROOM_CROSSING;
                    ACS_NamedExecute("roomChange",0,vCurrentScreen,196);
                    clear(UI_MENU);
                    clear(UI_MENUINFO);
                    clear(UI_MENUTEXT);
                    clear(UI_MENUSELECTOR);
                    Delay(10);
                    SetMusicVolume(1.0);
                    ACS_NamedExecute("sonataTimer",0);
                    Terminate;
                }
                else
                {
                    PlaySound(0,"RPGMISS",1);
                }
            }

            if (menuSelected == 2)
            {
                if (vHasBook)
                {
                    switch (vCurrentScreen)
                    {
                        case ROOM_MYSTERY:
                            PlaySound(0,"RPGTELE",1);
                            changeBGM(BGM_NONE,2,FALSE);
                            vLastScreen = vCurrentScreen;
                            vCurrentScreen = ROOM_CHURCH;
                            ACS_NamedExecute("roomChange",0,vCurrentScreen,ENTER_CHURCH);
                            clear(UI_MENU);
                            clear(UI_MENUINFO);
                            clear(UI_MENUTEXT);
                            clear(UI_MENUSELECTOR);
                            Delay(10);
                            SetMusicVolume(1.0);
                            Terminate;
                        break;

                        case ROOM_CHURCH:
                            PlaySound(0,"RPGTELE",1);
                            changeBGM(BGM_NONE,2,FALSE);
                            vLastScreen = vCurrentScreen;
                            vCurrentScreen = ROOM_MYSTERY;
                            ACS_NamedExecute("roomChange",0,vCurrentScreen,ENTER_MYSTERY+40);
                            clear(UI_MENU);
                            clear(UI_MENUINFO);
                            clear(UI_MENUTEXT);
                            clear(UI_MENUSELECTOR);
                            Delay(10);
                            SetMusicVolume(1.0);
                            Terminate;
                        break;

                        case ROOM_MOON_HOUSE_END:
                            if (vRealPos == 149)
                            {
                                PlaySound(0,"RPGTELE",1);
                                changeBGM(BGM_NONE,2,FALSE);
                                clear(UI_MENU);
                                clear(UI_MENUINFO);
                                clear(UI_MENUTEXT);
                                clear(UI_MENUSELECTOR);
                                Delay(5);
                                SetMusicVolume(1.0);
                                ACS_NamedExecute("b_initBattle",0,bENEMY_MOON1);
                                Terminate;
                            }
                            else
                            {
                                PlaySound(0,"RPGMISS",1);
                            }
                        break;

                        default:
                            PlaySound(0,"RPGMISS",1);
                        break;
                    }
                    drawHud();
                }
                else
                {
                    PlaySound(0,"RPGMISS",1);
                }
            }

            if (menuSelected == 3)
            {
                if (altBoss2Clear)
                {
                    PlaySound(0,"RPGMENUS",1);
                    vPowerSpeed = !vPowerSpeed;
                    draw("UNSCII",strParam(s:"RETURN\n",s:(vHasTeleport > 0 ? strParam(s:"TPORT\c[FamiGrey]x",i:vHasTeleport) : "\c[FamiGrey]..."),s:"\n",s:(vHasBook ? "PRAY" : "\c[FamiGrey]..."),s:"\n",s:(altBoss2Clear ? (vPowerSpeed ? "\c[FamiBlue]SPEED\n" : "\c[FamiRed]POWER\n") : "\c[FamiGrey]...\n\cl"),s:(GetCvar("diskDebug") ? "DEBUG\n" : "???\n"),s:"RESET"),UI_MENUTEXT,224.1,184.1);
                    drawHud();
                }
                else
                {
                    PlaySound(0,"RPGMISS",1);
                }
            }

            if (menuSelected == 4)
            {
                if (GetCvar("diskDebug"))
                {
                    PlaySound(0,"RPGMENUO",1);
                    vOpenedDebug = 1;
                    ACS_NamedExecuteWait("inGameDebugMenu",0);
                }
                else
                {
                    PlaySound(0,"RPGMISS",1);
                }
            }

            if (menuSelected == 5)
            {
                AmbientSound("FDSON",127);
                changeBGM(BGM_NONE,2,FALSE);
                ACS_NamedTerminate("sonataTimeDsiplay",0);
                clearAll();
                ACS_NamedExecute("titleMenu",0);
                SetMusicVolume(1.0);
                Terminate;
            }
        }
        draw("UNSCII",">",UI_MENUSELECTOR,216.1,184.1+((menuSelected*8)<<16));
        Delay(1);
    }
}

function void debugReWriter (int battleType)
{
    draw("UNSCII",strParam
    (
        s:strParam(s:(debugger ? "ON" : "OFF")),s:"\n",
        i:vCurrentScreen,s:"\n",
        i:vPosX,s:"\n",
        i:vPosY,s:"\n",
        i:vHP,s:"\n",
        i:battleType,s:"\n",
        s:strParam(s:(battlesOn ? "ON" : "OFF"))
    ),
    UI_DEBUGMENUVALUES,264.1,160.1);
}

function void debugRoomSwitch (void)
{
    ACS_NamedTerminate("sanity",0);
    clear(ZONE_SPRITE1);
    clear(ZONE_SPRITE2);
    clear(ZONE_SPRITE3);
    drawRoom(0);
    drawElph();
}

script "inGameDebugMenu" (void)
{
    int menuSelected = 0;
    int battleType = 0;
    draw("RPGDMENU","A",UI_DEBUGMENU,208.1,152.1);
    draw("UNSCII","INFO\nROOM\nPOSX\nPOSY\nMIND\nTEST\nBATT\nGIVE\nBACK",UI_DEBUGMENUTEXT,224.1,160.1);
    debugReWriter(battleType);
    while (1)
    {
        if (inputUp && menuSelected > 0)
        {
            menuSelected--;
            PlaySound(0,"RPGMENUS",1);
        }
        if (inputDown && menuSelected < 8)
        {
            menuSelected++;
            PlaySound(0,"RPGMENUS",1);
        }
        draw("UNSCII",">",UI_DEBUGMENUSELECTOR,216.1,160.1+((menuSelected*8)<<16));

        if (inputLeft)
        {
            if (menuSelected == 0)
            {
                ACS_NamedExecute("rpg_debugger",0);
                debugger = !debugger;
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 1)
            {
                vCurrentScreen--;
                if (vCurrentScreen < 0) {vCurrentScreen = 143;}
                debugRoomSwitch();
                Delay(1);
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 2)
            {
                vPosX--;
                if (vPosX < 0) {vPosX = 19;}
                drawElph();
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 3)
            {
                vPosY--;
                if (vPosY < 0) {vPosY = 13;}
                drawElph();
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 4)
            {
                vHP -= 5;
                if (vHP < 1) {vHP = 1;}
                drawHud();
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 5)
            {
               battleType--;
               if (battleType < 0) {battleType = 99;}
               debugReWriter(battleType);
               PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 6)
            {
                battlesOn = !battlesOn;
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
        }

        if (inputRight)
        {
            if (menuSelected == 0)
            {
                ACS_NamedExecute("rpg_debugger",0);
                debugger = !debugger;
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 1)
            {
                vCurrentScreen++;
                if (vCurrentScreen > 143) {vCurrentScreen = 0;}
                debugRoomSwitch();
                Delay(1);
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 2)
            {
                vPosX++;
                if (vPosX > 19) {vPosX = 0;}
                drawElph();
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 3)
            {
                vPosY++;
                if (vPosY > 13) {vPosY = 0;}
                drawElph();
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 4)
            {
                vHP += 5;
                if (vHP > 40) {vHP = 40;}
                drawHud();
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 5)
            {
               battleType++;
               if (battleType > 99) {battleType = 0;}
               debugReWriter(battleType);
               PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 6)
            {
                battlesOn = !battlesOn;
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
        }

        if (inputUse)
        {
            if (menuSelected == 5)
            {
                SetMusicVolume(1.0);
                ACS_NamedTerminate("inGameMenu",0);
                clear(UI_MENU);
                clear(UI_MENUINFO);
                clear(UI_MENUTEXT);
                clear(UI_MENUSELECTOR);
                Clear(UI_DEBUGMENU);
                Clear(UI_DEBUGMENUTEXT);
                Clear(UI_DEBUGMENUSELECTOR);
                Clear(UI_DEBUGMENUVALUES);
                vHasControl = 1;
                ACS_NamedExecute("b_initBattle",0,battleType*12);
                Terminate;
            }
            if (menuSelected == 7)
            {
                PlaySound(0,"RPGMENUS",1);
                debugGive();
                drawHud();
            }

            if (menuSelected ==8)
            {
                PlaySound(0,"RPGMENUB",1);
                Clear(UI_DEBUGMENU);
                Clear(UI_DEBUGMENUTEXT);
                Clear(UI_DEBUGMENUSELECTOR);
                Clear(UI_DEBUGMENUVALUES);
                Terminate;
            }
        }
        Delay(1);
    }
}

script "HPtracker" (void)
{
    While (vHP > 0)
    {
        Delay(5);
    }
    if (vCurrentScreen == ROOM_HOMEMOON)
    {
        ACS_NamedTerminate("sanity",0);
        ACS_NamedExecute("gameOver",0,GO_MOONROOM);
        Terminate;
    }
}

script "gameOver" (int type)
{
    drawTime = 0;
    ACS_NamedTerminate("sonataTimer",0);
    vHP = 0;
    changeBGM(BGM_NONE,2,FALSE);
    clearAll();
    debugMessage="";
    debugMessage2="";
    debugMessage3="";
    vHasControl = 0;
    vRealPos = 0;
    vWishPos = 0;
    vPosX = 0;
    vPosY = 0;

    if (type == GO_MOONROOM)
    {
        Delay(20);
        debugmessage2 = "SCREEN_GAMEOVER\n";
        draw("RPGOVER","A",ZONE_BG,160.0,192.2);
        draw("UNSCII","GAME OVER",ZONE_ROOM,160.0,208.2);
        changeBGM(BGM_MOONISH,1,FALSE);
        Delay(15);
        debugmessage2 = "";
        clear(ZONE_BG);
        clear(ZONE_ROOM);
        changeBGM(BGM_NONE,2,FALSE);
        Delay(5);
        debugmessage2 = "SCREEN_ILLDOITAGAIN\n";
        draw("GO_ANGEL","A",ZONE_BG,160.0,208.2);
        draw("UNSCII","******* ********",ZONE_ROOM,160.0,224.2);
        changeBGM(BGM_ANGEL,2,FALSE);
        Delay(65);
        changeBGM(BGM_NONE,2,FALSE);
        clear(ZONE_BG);
        clear(ZONE_ROOM);
        Delay(10);
        ACS_NamedExecute("titleMenu",0);
    }

    if (type == GO_NORMAL || type == GO_GUTS)
    {
        if (type == GO_GUTS)
        {
            for (int i = 0; i < 14; i++)
            {
                int eyeCount = i+1;
                if (eyeCount > 4) {eyeCount = 5+(i%2);}
                draw(strParam(s:"RPGEYE",i:eyeCount),"A",UI_HUDFACE,0.1,0.1);
                Delay((i < 2 ? 4 : 2));
            }
            clear(UI_HUDFACE);
        }
        Delay(20);
        debugmessage2 = "SCREEN_GAMEOVER\n";
        draw("RPGOVER","A",ZONE_BG,160.0,192.2);
        draw("UNSCII","GAME OVER",ZONE_ROOM,160.0,208.2);
        changeBGM(BGM_MOONISH,1,FALSE);
        while (!inputUse)
        {
            Delay(1);
            debugMessageInput = StrParam(s:"WAIT");
        }
        debugMessageInput = "";
        changeBGM(BGM_NONE,2,FALSE);
        clear(ZONE_BG);
        clear(ZONE_ROOM);
        Delay(10);
        ACS_NamedExecute("titleMenu",0);
    }
}

script "sanity" (void)
{
    while (1)
    {
        for (int i = 0; i < 15; i++)
        {
            Delay(2);
            debugmessage2 = strParam(s:"TIME ", i:vSanityTimer, s:".", i:i, s:"\n", i:(vSanityTimer/5), s:" DMG\n");
        }
        if (vHasControl)
        {
            vSanityTimer++;
            if (vSanityTimer > 2)
            {
                vHP -= vSanityTimer/3;
            }
            drawHud();
        }
        Delay(1);
        if (vHP < 0)
        {
            ACS_NamedExecute("gameOver",0,GO_MOONROOM);
            Terminate;
        }
    }
}

#include "SN_BATL.ACS"

bool screenOn = 0;

script "tvEvent" (void)
{
    drawTime = 0;
    clearAll();
    changeBGM(BGM_NONE,0,0);
    vHasControl = 0;
    Delay(10);
    changeBGM(BGM_NOISE,0,0);
    str screenTexture = "";
    screenOn = 1;
    ACS_NamedExecute("tvEventExiter",0);
    while (screenOn)
    {
        switch (random(0,2))
        {
            case 0:
            screenTexture = "RPGSCRN1";
            break;

            case 1:
            screenTexture = "RPGSCRN3";
            break;

            case 2:
            screenTexture = "RPGSCRN5";
            break;
        }
        draw(screenTexture, "A", ZONE_BG, 160.0, 128.0);
        delay(getRNG()%16);
    }
    clear(ZONE_BG);
    changeBGM(BGM_NONE,0,0);
    Delay(10);
    ChangeBGM(vLastMusic,vLastMusicFile,TRUE);
    drawRoom(0);
    drawElph();
    drawHud();
    vHasControl = 1;
    drawTime = 1;
}

script "tvEventExiter" (void)
{
    while (screenOn)
    {
        if (inputUse)
        {
            screenOn = 0;
        }
        Delay(1);
    }
}

#define BOW_COST 100
#define MELEE_COST 100
#define BOMB_COST 150
#define POTION_COST 150
#define TP_COST 50
#define SLOTS_COST 1000

function void drawShop (int menuOption)
{
    draw("UNSCII",strParam
    (
        s:vBowBoost < 2 ? strParam(s:"RANGED UP \c[FamiGold]",i:BOW_COST+(50*vBowBoost),s:"G\nCURRENT:  LV",i:vBowBoost+1) : strParam(s:"\c[FamiRed]SOLD OUT\nCURRENT:  LV",i:vBowBoost+1),s:"\n\n",
        s:vMeleeBoost < 2 ? strParam(s:"MELEE UP  \c[FamiGold]",i:MELEE_COST+(50*vMeleeBoost),s:"G\nCURRENT:  LV",i:vMeleeBoost+1) : strParam(s:"\c[FamiRed]SOLD OUT\nCURRENT:  LV",i:vMeleeBoost+1),s:"\n\n",
        s:vHasBomb ? strParam(s:"\c[FamiRed]SOLD OUT\nYOU HAVE: ",i:vHasBomb) : strParam(s:"BOMB      \c[FamiGold]",i:BOMB_COST,s:"G\nYOU HAVE: ",i:vHasBomb),s:"\n\n",
        s:vHasPotion ? strParam(s:"\c[FamiRed]SOLD OUT\nYOU HAVE: ",i:vHasPotion) : strParam(s:"POTION    \c[FamiGold]",i:POTION_COST,s:"G\nYOU HAVE: ",i:vHasPotion),s:"\n\n",
        s:vHasTeleport >= 9 ? strParam(s:"\c[FamiRed]SOLD OUT\nYOU HAVE: ",i:vHasTeleport) : strParam(s:"TELEPORT  \c[FamiGold]",i:TP_COST,s:"G\nYOU HAVE: ",i:vHasTeleport),s:"\n\n",
        s:vHasSlowSlots ? strParam(s:"\c[FamiRed]SOLD OUT\nYOU HAVE: ",i:vHasSlowSlots) : strParam(s:"SLOWSLOTS \c[FamiGold]",i:SLOTS_COST,s:"G\nYOU HAVE: ",i:vHasSlowSlots),s:"\n\n",
        s:"GOODBYE\n\n\n\n\n\nGOLD: \c[FamiGold]",i:vGold
    ),
    3500, 40.1,32.1);
    draw("UNSCII",">",3501,16.1,32.1+((menuOption*24)<<16));
    draw(vBowBoost < 2 ? vBowBoost < 1 ? "RPGBBOW0" : "RPGBBOW1" : "RPGBBOW2","A",3499,24.1,32.1);
    draw(vMeleeBoost < 2 ? vMeleeBoost < 1 ? "RPGBMEL0" : "RPGBMEL1" : "RPGBMEL2","A",3498,24.1,56.1);
    draw("RPGBOM","A",3497,24.1,80.1);
    draw("RPGPOT","A",3496,24.1,104.1);
    draw("RPGTPORT","A",3495,24.1,128.1);
    draw("RPGSSLT","A",3494,24.1,152.1);
}

script "shopping" (void)
{
    drawTime = 0;
    vHasControl = 0;
    clearAll();
    changeBGM(BGM_NONE,0,0);
    Delay(10);
    PlaySound(0,"RPGTUNL",2);
    int menuSelected = 0;
    bool inShop = 1;
    draw("RPGSHOP","A",3502,320.2,248.2);
    drawShop(menuSelected);
    Delay(20);
    changeBGM(BGM_SHOP,0,0);

    while (inShop)
    {
        if (inputUp && menuSelected > 0)
        {
            menuSelected--;
            PlaySound(0,"RPGMENUS",1);
            drawShop(menuSelected);
        }
        if (inputDown && menuSelected < 6)
        {
            menuSelected++;
            PlaySound(0,"RPGMENUS",1);
            drawShop(menuSelected);
        }
        if (inputUse)
        {
            switch (menuSelected)
            {
                case 0:
                if (vBowBoost < 2 && vGold >= BOW_COST+(50*vBowBoost))
                {
                    PlaySound(0,"RPGMENUO",1);
                    PlaySound(0,"RPGTUNL1",2);
                    vGold -= BOW_COST+(50*vBowBoost);
                    vBowBoost++;
                }
                else {PlaySound(0,"RPGMISS",1);}
                break;

                case 1:
                if (vMeleeBoost < 2 && vGold >= MELEE_COST+(50*vMeleeBoost))
                {
                    PlaySound(0,"RPGMENUO",1);
                    PlaySound(0,"RPGTUNL1",2);
                    vGold -= MELEE_COST+(50*vMeleeBoost);
                    vMeleeBoost++;
                }
                else {PlaySound(0,"RPGMISS",1);}
                break;

                case 2:
                if (!vHasBomb && vGold >= BOMB_COST)
                {
                    PlaySound(0,"RPGMENUO",1);
                    PlaySound(0,"RPGTUNL1",2);
                    vHasBomb = 1;;
                    vGold -= BOMB_COST;
                }
                else {PlaySound(0,"RPGMISS",1);}
                break;

                case 3:
                if (!vHasPotion && vGold >= POTION_COST)
                {
                    PlaySound(0,"RPGMENUO",1);
                    PlaySound(0,"RPGTUNL1",2);
                    vHasPotion = 1;;
                    vGold -= POTION_COST;
                }
                else {PlaySound(0,"RPGMISS",1);}
                break;

                case 4:
                if (vHasTeleport < 9 && vGold >= TP_COST)
                {
                    PlaySound(0,"RPGMENUO",1);
                    PlaySound(0,"RPGTUNL1",2);
                    vHasTeleport++;
                    vGold -= TP_COST;
                }
                else {PlaySound(0,"RPGMISS",1);}
                break;

                case 5:
                if (!vHasSlowSlots && vGold >= SLOTS_COST)
                {
                    PlaySound(0,"RPGMENUO",1);
                    PlaySound(0,"RPGTUNL1",2);
                    vHasSlowSlots = 1;;
                    vGold -= SLOTS_COST;
                }
                else {PlaySound(0,"RPGMISS",1);}
                break;

                case 6:
                changeBGM(BGM_NONE,0,0);
                PlaySound(0,"RPGTUNL2",2);
                inShop = 0;
                Delay(35);
                break;
            }
            drawShop(menuSelected);
        }
        Delay(1);
    }

    clear(3502);
    clear(3501);
    clear(3500);
    clear(3494);
    clear(3495);
    clear(3496);
    clear(3497);
    clear(3498);
    clear(3499);
    clearAll();
    Delay(10);
    drawRoom(0);
    drawElph();
    drawHud();
    vHasControl = 1;
    drawTime = 1;
    ChangeBGM(vLastMusic,vLastMusicFile,TRUE);
}

script "teleportBuffer" (void)
{
    switch (vCurrentScreen)
    {
        case ROOM_STAR_MAZE_A:
        case ROOM_STAR_MAZE_B:
        case ROOM_STAR_MAZE_C:
        case ROOM_STAR_MAZE_D:
            vTeleportBufferTime = 10;
            break;

        default:
            vTeleportBufferTime = 22;
            break;
    }

    while (vTeleportBufferTime > 0)
    {
        vTeleportBufferTime--;
        Delay(1);
    }
    vTeleportBufferTime = 0;
}