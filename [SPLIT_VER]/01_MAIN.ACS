script "mainInput" ENTER
{
    while(1)
    {
        inputUse =
        ((GetPlayerInput(0,INPUT_BUTTONS) & BT_USE) && !(GetPlayerInput(0,INPUT_OLDBUTTONS) & BT_USE))
        || ((GetPlayerInput(0,INPUT_BUTTONS) & BT_SNUSE) && !(GetPlayerInput(0,INPUT_OLDBUTTONS) & BT_SNUSE));

        inputUp =
        ((GetPlayerInput(0,INPUT_BUTTONS) & BT_FORWARD) && !(GetPlayerInput(0,INPUT_OLDBUTTONS) & BT_FORWARD))
        || ((GetPlayerInput(0,INPUT_BUTTONS) & BT_SNUP) && !(GetPlayerInput(0,INPUT_OLDBUTTONS) & BT_SNUP));

        inputDown =
        ((GetPlayerInput(0,INPUT_BUTTONS) & BT_BACK) && !(GetPlayerInput(0,INPUT_OLDBUTTONS) & BT_BACK))
        || ((GetPlayerInput(0,INPUT_BUTTONS) & BT_SNDOWN) && !(GetPlayerInput(0,INPUT_OLDBUTTONS) & BT_SNDOWN));

        inputLeft =
        ((GetPlayerInput(0,INPUT_BUTTONS) & BT_MOVELEFT) && !(GetPlayerInput(0,INPUT_OLDBUTTONS) & BT_MOVELEFT))
        || ((GetPlayerInput(0,INPUT_BUTTONS) & BT_SNLEFT) && !(GetPlayerInput(0,INPUT_OLDBUTTONS) & BT_SNLEFT));

        inputRight =
        ((GetPlayerInput(0,INPUT_BUTTONS) & BT_MOVERIGHT) && !(GetPlayerInput(0,INPUT_OLDBUTTONS) & BT_MOVERIGHT))
        || ((GetPlayerInput(0,INPUT_BUTTONS) & BT_SNRIGHT) && !(GetPlayerInput(0,INPUT_OLDBUTTONS) & BT_SNRIGHT));

        inputUpHold =
        ((GetPlayerInput(0,INPUT_BUTTONS) & BT_FORWARD))
        || ((GetPlayerInput(0,INPUT_BUTTONS) & BT_SNUP));

        inputDownHold =
        ((GetPlayerInput(0,INPUT_BUTTONS) & BT_BACK))
        || ((GetPlayerInput(0,INPUT_BUTTONS) & BT_SNDOWN));

        inputLeftHold =
        ((GetPlayerInput(0,INPUT_BUTTONS) & BT_MOVELEFT))
        || ((GetPlayerInput(0,INPUT_BUTTONS) & BT_SNLEFT));

        inputRightHold =
        ((GetPlayerInput(0,INPUT_BUTTONS) & BT_MOVERIGHT))
        || ((GetPlayerInput(0,INPUT_BUTTONS) & BT_SNRIGHT));

        Delay(1);
    }
}

script "rpg_debugger" (void)
{
    str input1 = "";
    str input2 = "";
    str input3 = "";
    str input4 = "";
    str input5 = "";
    str debugInfo = "";
    str debugInfo2 = "";
    while (debugger)
    {
    if (!bSafetyCheck)
    {
        debugInfo =
        StrParam(
            s:"ROOM ",i:vCurrentScreen,s:" \n",
            s:"POSX ",i:vPosX,s:".",i:vTweenX*TWEEN_MULT,s:" \n",
            s:"POSY ",i:vPosY,s:".",i:vTweenY*TWEEN_MULT,s:" \n",
            s:"REAL ",i:vRealPos,s:" \n",
            s:"WISH ",i:vWishPos,s:" \n",
            s:"CTRL ",b:vHasControl,s:" \n",
            s:"RNGV ",i:RNG[RNGcount],s:" \n",
            s:"RNGN ",i:RNG[RNGcount+1%64],s:" \n",
            s:"RNGS ",i:RNGcount,s:" \n",
            s:"IN_P ",s:debugMessageInput,s:"\n",
            s:"IN_R ",s:debugMessageRealInput,s:"\n",
            s:"STEP ",i:vStepCount,s:"\n",
            s:"NME1 ",i:areaEncounters[0],s:"\n",
            s:"NME2 ",i:areaEncounters[1],s:"\n",
            s:"USED ",s:debugInteract,s:" \n",
            s:"MODP ",i:vLastMusic,s:" \n",
            s:"TIME ",i:sonataTime
        );
        debugInfo2 = StrParam(s:"\n",s:debugMessage,s:debugMessage2,s:debugMessage3);
    }
    if (bSafetyCheck)
    {
        debugInfo =
        StrParam(
            s:"TYPE ",i:bEnemyType,s:" \n",
            s:"REAL ",i:bElphPos,s:" \n",
            s:"HURT ",b:bElphHurt,s:" \n",
            s:"MOVE ",b:bMoved,s:" \n",
            s:"ATBV ",i:bATBvalue,s:"\n",
            s:"ATB1 ",b:bATBactive,s:"\n",
            s:"RNGV ",i:RNG[RNGcount],s:" \n",
            s:"RNGN ",i:RNG[RNGcount+1%64],s:" \n",
            s:"RNGS ",i:RNGcount,s:" \n",
            s:"CTRL ",b:bHasControl,s:"\n",
            s:"NMEY ",i:bYOffset,s:" \n",
            s:"NMEX ",i:bXOffset,s:" \n",
            s:"MODP ",i:enemyDB[bEnemyType+7],s:":",i:enemyDB[bEnemyType+8],s:" \n",
            s:"TIME ",i:sonataTime
        );
        debugInfo2 = StrParam(s:debugMessage,s:debugMessage2,s:debugMessage3);
    }
    draw("UNSCII",debugInfo,UI_DEBUG,8.1,248.2);
    draw("UNSCII",debugInfo2,UI_DEBUG2,8.1,40.1);
    draw("RPGPOSW","A",UI_DEBUGWISH,(((vWishPos%20)*16)<<16)+0.1,(((vWishPos/20)*16)<<16)+32.1);
    draw("RPGPOSR","A",UI_DEBUGREAL,((vPosX*16)<<16)+0.1,((vPosY*16)<<16)+32.1);

    // input display
    if (inputRightHold) {input1 = "R";} else {input1 = "";}
    if (inputLeftHold) {input2 = "L";} else {input2 = "";}
    if (inputUpHold) {input3 = "U";} else {input3 = "";}
    if (inputDownHold) {input4 = "D";} else {input4 = "";}
    if (inputUse) {input5 = "1";} else {input5 = "";}
    debugMessageRealInput = strParam(s:input1,s:input2,s:input3,s:input4,s:input5);
    Delay(1);
    }
    clear(UI_DEBUG);
    clear(UI_DEBUG2);
    clear(UI_DEBUG3);
    clear(UI_DEBUGWISH);
    clear(UI_DEBUGREAL);
}

script "sonataTimer" (void)
{
    sonataTime = 0;
    while (1)
    {
        sonataTime++;
        Delay(1);
    }
}

script "sonataTimeDsiplay" (void)
{
    while (1)
    {
    int sTimeS = sonataTime/35;
    int sTimeSec = sTimeS % 60;
    int sTimeMin = (sTimeS / 60) % 60;
    int sTimeHr = sTimeS / 3600;
    sonataTimeDisplay = strParam(i:sTimeHr/10,i:sTimeHr%10,s:":",i:sTimeMin/10,i:sTimeMin%10,s:":",i:sTimeSec/10,i:sTimeSec%10);
    if (drawTime) {drawHud();}
    Delay(35);
    }
}

script "rpg_Starter" ENTER
{
    killCount =
        (
            GetCvar("shroKills") +
            GetCvar("abutKills") +
            GetCvar("akasKills") +
            GetCvar("beasKills") +
            GetCvar("beliKills") +
            GetCvar("blooKills") +
            GetCvar("commKills") +
            GetCvar("demoKills") +
            GetCvar("direKills") +
            GetCvar("drauKills") +
            GetCvar("moonKills") +
            GetCvar("follKills") +
            GetCvar("flesKills") +
            GetCvar("railKills") +
            GetCvar("gargKills") +
            GetCvar("growKills") +
            GetCvar("hellKills") +
            GetCvar("lunaKills") +
            GetCvar("maliKills") +
            GetCvar("procKills") +
            GetCvar("sentKills") +
            GetCvar("wallKills") +
            GetCvar("watcKills") +
            GetCvar("zealKills") +
            GetCvar("nitrKills")
        ) / 500;
    killCount = killCount > 10 ? 10 : killCount;
    AmbientSound("FDSON",127);
    PlaySound(0,"LINENOIS",7,1.0,TRUE);
    FadeTo(0,0,0,1.0,0.0);
    SetPlayerProperty(0,1,PROP_TOTALLYFROZEN);
    Delay(1);
    ScriptCall("postProcKiller","postProcOff");
    ScriptCall("postProcKiller","NTSCOn");
	setRes();
    SetFont("RPGSTAT0");
    HudMessage(s:"A";HUDMSG_PLAIN|HUDMSG_ALPHA|HUDMSG_LAYER_OVERHUD,UI_STATIC,CR_UNTRANSLATED,160.0,128.0,0,0.01);
	SetFont("RPGBRDR");
	HudMessage(s:"A";HUDMSG_PLAIN|HUDMSG_LAYER_OVERHUD,UI_BORDER,CR_UNTRANSLATED,0.2,0.1,0);
	SetFont("RPGBRDR");
	HudMessage(s:"A";HUDMSG_PLAIN|HUDMSG_LAYER_OVERHUD,UI_BORDER+1,CR_UNTRANSLATED,320.1,0.1,0);
	ACS_NamedExecute("titleMenu",0);
}

