// enemy patterns

script "b_attackPatterns0" (void) // VICTIM
{
    b_enemyAttacking(0);
    int short = 7+vHardMode;
    int mid = 20+vHardMode;
    int long = (getRNG()%40+40)+vHardMode;
    int attack = getRNG()%5;
    if (debugger) {debugMessage = strParam(s:"S",i:short,s:" M",i:mid,s:" L",i:long,s:"\n");}

    switch (attack)
    {
        case 0:
            b_enemyAttacking(1);
            b_attackPass(6,0); delay(short);
            b_attackPass(3,0); delay(short);
            b_attackPass(0,0); delay(mid);
            b_attackPass(1,0); delay(short);
            b_attackPass(4,0); delay(short);
            b_attackPass(7,0); delay(mid);
            b_attackPass(8,0); delay(short);
            b_attackPass(5,0); delay(short);
            b_attackPass(2,0);
            break;

        case 1:
            b_enemyAttacking(1);
            b_attackGrid(bATK_COL_L); Delay(mid);
            b_attackGrid(bATK_COL_M); Delay(mid);
            b_attackGrid(bATK_COL_R);
            break;

        case 2:
            b_enemyAttacking(1);
            b_attackGrid(bATK_COL_R); Delay(mid);
            b_attackGrid(bATK_COL_M); Delay(mid);
            b_attackGrid(bATK_COL_L);
            break;

        case 3:
            b_enemyAttacking(1);
            b_attackGrid(bATK_ROW_U); Delay(mid);
            b_attackGrid(bATK_ROW_M); Delay(mid);
            b_attackGrid(bATK_ROW_B);
            break;

        case 4:
            b_enemyAttacking(1);
            b_attackGrid(bATK_ROW_B); Delay(mid);
            b_attackGrid(bATK_ROW_M); Delay(mid);
            b_attackGrid(bATK_ROW_U);
            break;
    }
    b_enemyAttacking(0);
	Delay(long);
    Restart;
}

script "b_attackPatterns12" (void) // CHICKEN
{
    b_enemyAttacking(0);
    int short = 4+vHardMode;
    int mid = 15+vHardMode;
    int long = (getRNG()%30+30+vHardMode);
    int attack = getRNG()%4;
    if (debugger) {debugMessage = strParam(s:"S",i:short,s:" M",i:mid,s:" L",i:long,s:"\n");}

    switch (attack)
    {
        case 0:
            b_enemyAttacking(1);
            b_attackPass(2,0); delay(short);
            b_attackPass(4,0); delay(short);
            b_attackPass(6,0); delay(short);
            Delay(mid+getRNG()%11);
            b_attackPass(0,0); delay(short);
            b_attackPass(4,0); delay(short);
            b_attackPass(8,0);
            break;

        case 1:
            b_enemyAttacking(1);
            b_attackGrid(bATK_SLASH_F); Delay(mid);
            b_attackGrid(bATK_COL_M); Delay(mid);
            b_attackGrid(bATK_SLASH_B); Delay(mid);
            b_attackGrid(bATK_ROW_M); Delay(mid);
            b_attackGrid(bATK_SLASH_F); Delay(mid);
            b_attackGrid(bATK_COL_M); Delay(mid);
            b_attackGrid(bATK_SLASH_B); Delay(mid);
            b_attackGrid(bATK_ROW_M);
            break;

        case 2:
            b_enemyAttacking(1);
            b_attackGrid(bATK_SLASH_B); Delay(mid);
            b_attackGrid(bATK_COL_M); Delay(mid);
            b_attackGrid(bATK_SLASH_F); Delay(mid);
            b_attackGrid(bATK_ROW_M); Delay(mid);
            b_attackGrid(bATK_SLASH_B); Delay(mid);
            b_attackGrid(bATK_COL_M); Delay(mid);
            b_attackGrid(bATK_SLASH_F); Delay(mid);
            b_attackGrid(bATK_ROW_M);
            break;

        case 3:
            b_enemyAttacking(1);
            for (int i = 0; i < getRNG()%2+3; i++)
            {
                b_attackGrid(bATK_COL_M); Delay(mid);
                b_attackGrid(bATK_COL_L);
                b_attackGrid(bATK_COL_R); Delay(mid+getRNG()%10+10);
            }
        break;
    }
    b_enemyAttacking(0);
    Delay(long);
    Restart;
}

script "b_attackPatterns24" (void) // PRAYER && SHADOW
{
    b_enemyAttacking(0);
    int short = 4+vHardMode;
    int mid = 13+vHardMode;
    int long = getRNG()%30+40+vHardMode;
    int attack = getRNG()%4;
    if (debugger) {debugMessage = strParam(s:"S",i:short,s:" M",i:mid,s:" L",i:long,s:"\n");}

    switch (getRNG()%4)
    {
        case 0:
            b_enemyAttacking(1);
            b_attackPass(2,45);
            b_attackPass(5,45);
            b_attackPass(8,45);
            delay(mid);
            break;

        case 1:
            b_enemyAttacking(1);
            b_attackPass(0,45);
            b_attackPass(3,45);
            b_attackPass(6,45);
            delay(mid);
            break;

        case 2:
            b_enemyAttacking(1);
            b_attackPass(0,45);
            b_attackPass(2,45);
            b_attackPass(6,45);
            b_attackPass(8,45);
            delay(mid);
            break;

        case 3:
            b_enemyAttacking(1);
            b_attackPass(4,45);
            break;
    }
    for (int i = 0; i < 8; i++)
        {
            b_attackPass(bElphPos,0); delay(mid);
        }
    b_enemyAttacking(0);
    Delay(long);
    Restart;
}

script "b_attackPatterns36" (void) // SEER
{
    b_enemyAttacking(0);
    int short = 15+vHardMode;
    int mid = 20+vHardMode;
    int long = getRNG()%30+40+vHardMode;
    int attack = getRNG()%3;
    if (debugger) {debugMessage = strParam(s:"S",i:short,s:" M",i:mid,s:" L",i:long,s:"\n");}

    switch (attack)
    {
        case 0:
            b_enemyAttacking(1);
            for (int nSteps = 0 ; nSteps < getRNG()%4+8; nSteps++)
            {
                b_attackPass(bElphPos,0);
                Delay(getRNG()%9+9+vHardMode);
            }
            break;

        case 1:
            b_enemyAttacking(1);
            for (int i = 0; i < 4; i++)
            {
                b_attackPass(bElphPos,0);
                b_attackPass((bElphPos+3)%9,0);
                b_attackPass((bElphPos-3+8)%9,0);
                Delay(getRNG()%30+20+vHardMode);
            }
            break;

        case 2:
            b_enemyAttacking(1);
            b_attackGrid(bATK_O);
            Delay(mid);
            b_attackPass(4,0);
            Delay(mid);
            b_attackGrid(bATK_O);
            Delay(mid);
            b_attackPass(4,0);
            Delay(mid);
            b_attackGrid(bATK_O);
            Delay(short);
            b_attackPass(4,0);
            Delay(short);
            b_attackGrid(bATK_O);
            Delay(short);
            b_attackPass(4,0);
            break;
    }
    b_enemyAttacking(0);
	Delay(long);
    Restart;
}

