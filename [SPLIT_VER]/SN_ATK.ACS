script "b_attackPatterns168" (void) // HOLY
{
    b_enemyAttacking(0);
    int short = (vHardMode == 2 ? 9 : 6+vHardMode);
    int mid = 16+vHardMode;
    int long = getRNG()%20+40+vHardMode;
    int attack = getRNG()%2;
    if (debugger) {debugMessage = strParam(s:"S",i:short,s:" M",i:mid,s:" L",i:long,s:"\n");}

    switch (attack)
    {
        case 0:
            b_enemyAttacking(1);
            for (int i = 0; i < 6; i++)
            {
                switch (getRNG()%2)
                {
                    case 0:
                    b_attackPass(0,0);
                    b_attackPass(1,0);
                    b_attackPass(3,0); Delay(short);

                    b_attackPass(0,0);
                    b_attackPass(3,0);
                    b_attackPass(6,0);
                    b_attackPass(4,0); Delay(short);

                    b_attackPass(3,0);
                    b_attackPass(6,0);
                    b_attackPass(7,0); Delay(mid);
                    break;

                    case 1:
                    b_attackPass(1,0);
                    b_attackPass(2,0);
                    b_attackPass(5,0); Delay(short);

                    b_attackPass(2,0);
                    b_attackPass(4,0);
                    b_attackPass(5,0);
                    b_attackPass(8,0); Delay(short);

                    b_attackPass(5,0);
                    b_attackPass(7,0);
                    b_attackPass(8,0); Delay(mid);
                    break;
                }
            }
        break;

        case 1:
            b_enemyAttacking(1);
            for (int j = 0; j < 6; j++)
            {
                int row = bElphPos / 3;
                switch (row)
                {
                    case 0:
                        b_attackGrid(bATK_ROW_U);
                        b_attackPass(bElphPos,20);
                    break;

                    case 1:
                        b_attackGrid(bATK_ROW_M);
                        b_attackPass(bElphPos,20);
                    break;

                    case 2:
                        b_attackGrid(bATK_ROW_B);
                        b_attackPass(bElphPos,20);
                    break;
                }
                Delay(mid+6);
            }
        break;
    }
    b_enemyAttacking(0);
	Delay(long);
    Restart;
}

