script "b_attackPatterns60" (void) // GUTS
{
    b_enemyAttacking(0);
    int short = (vHardMode == 2 ? 14 : 10+vHardMode);
    int mid = (vHardMode == 2 ? 18 : 14+vHardMode);
    int long = getRNG()%20+50+vHardMode;
    int attack = getRNG()%6;
    if (debugger) {debugMessage = strParam(s:"S",i:short,s:" M",i:mid,s:" L",i:long,s:"\n");}

    switch (attack)
    {
        case 0:
            b_enemyAttacking(1);
            b_attackPass(0,0); Delay(3+vHardMode);
            b_attackPass(1,0); Delay(3+vHardMode);
            b_attackPass(2,0); Delay(3+vHardMode);
            b_attackPass(5,0); Delay(3+vHardMode);
            b_attackPass(4,0); Delay(3+vHardMode);
            b_attackPass(3,0); Delay(3+vHardMode);
            b_attackPass(6,0); Delay(3+vHardMode);
            b_attackPass(7,0); Delay(3+vHardMode);
            b_attackPass(8,0); Delay(mid);
            b_attackPass(8,0); Delay(3+vHardMode);
            b_attackPass(7,0); Delay(3+vHardMode);
            b_attackPass(6,0); Delay(3+vHardMode);
            b_attackPass(3,0); Delay(3+vHardMode);
            b_attackPass(4,0); Delay(3+vHardMode);
            b_attackPass(5,0); Delay(3+vHardMode);
            b_attackPass(3,0); Delay(3+vHardMode);
            b_attackPass(2,0); Delay(3+vHardMode);
            b_attackPass(1,0); Delay(3+vHardMode);
            b_attackPass(0,0);
            break;

        case 1:
            b_enemyAttacking(1);
            b_attackPass(0,0);
            b_attackPass(1,0); delay(mid);
            b_attackPass(4,0);
            b_attackPass(5,0); delay(mid);
            b_attackPass(6,0);
            b_attackPass(7,0); delay(30+vHardMode);
            b_attackPass(1,0);
            b_attackPass(2,0); delay(mid);
            b_attackPass(3,0);
            b_attackPass(4,0); delay(mid);
            b_attackPass(7,0);
            b_attackPass(8,0);
            break;

        case 2:
            b_enemyAttacking(1);
            b_attackPass(0,40);
            b_attackPass(1,40);
            b_attackPass(2,40);
            b_attackPass(6,40);
            b_attackPass(7,40);
            b_attackPass(8,40);
            delay(mid);

            for (int i = 0; i < 3; i++)
            {
                b_attackPass(3,0); delay(short);
                b_attackPass(4,0); delay(short);
                b_attackPass(5,0); delay(short);
            }
            break;

        case 3:
            b_enemyAttacking(1);
            b_attackPass(0,40);
            b_attackPass(2,40);
            b_attackPass(3,40);
            b_attackPass(5,40);
            b_attackPass(6,40);
            b_attackPass(8,40);
            delay(mid);

            for (int j = 0; j < 3; j++)
            {
                b_attackPass(1,0); delay(short);
                b_attackPass(4,0); delay(short);
                b_attackPass(7,0); delay(short);
            }
            break;

        case 4:
            b_enemyAttacking(1);
            b_attackPass(0,0); delay(5+vHardMode);
            b_attackPass(4,0); delay(5+vHardMode);
            b_attackPass(8,0); delay(5+vHardMode);
            b_attackPass(7,0); delay(5+vHardMode);
            b_attackPass(6,0); delay(5+vHardMode);
            b_attackPass(4,0); delay(5+vHardMode);
            b_attackPass(2,0); delay(5+vHardMode);
            b_attackPass(1,0); delay(5+vHardMode);
            b_attackPass(0,0); delay(5+vHardMode);
            b_attackPass(3,0); delay(5+vHardMode);
            b_attackPass(6,0); delay(5+vHardMode);
            b_attackPass(4,0); delay(5+vHardMode);
            b_attackPass(2,0); delay(5+vHardMode);
            b_attackPass(5,0); delay(5+vHardMode);
            b_attackPass(8,0); delay(5+vHardMode);
            break;
    }
    b_enemyAttacking(0);
	Delay(long);
    Restart;
}

