script "b_attackPatterns108" (void) // ELPH
{
    b_enemyAttacking(0);
    int short = (vHardMode == 7 ? 14 : 4+vHardMode);
    int mid = 10+vHardMode;
    int long = getRNG()%25+25+vHardMode;
    int attack = getRNG()%2;
    if (debugger) {debugMessage = strParam(s:"S",i:short,s:" M",i:mid,s:" L",i:long,s:"\n");}

    if (bEnemyHP < 100)
    {
        switch (attack)
        {
            case 0:
                b_enemyAttacking(1);
                for (int i = 0; i < (getRNG()%16)+8; i++)
                {
                    b_attackPass(bElphPos,0); delay(short);
                }
                break;

            case 1:
                b_enemyAttacking(1);
                for (int j = 0; j < (getRNG()%4)+4; j++)
                {
                    b_attackPass(getRNG()%9,0); delay(2);
                }
                break;
        }
    }
    b_enemyAttacking(0);
    Delay(long);
    Restart;
}

