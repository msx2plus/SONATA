            b_attackPass(7,15); delay(short);
            b_attackPass(4,15);
            b_attackPass(6,15);
            b_attackPass(8,15); delay(short);
            b_attackPass(1,15);
            b_attackPass(3,15);
            b_attackPass(5,15); delay(short);
            break;
    }
    b_enemyAttacking(0);
	Delay(long);
    Restart;
}

