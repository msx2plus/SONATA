script "b_attackPatterns84" (void) // BURROWER
{
    b_enemyAttacking(0);
    int short = (vHardMode == 2 ? 8 : 4+vHardMode);
    int mid = 12+vHardMode;
    int long = getRNG()%30+30+vHardMode;
    int attack = getRNG()%5;
    if (debugger) {debugMessage = strParam(s:"S",i:short,s:" M",i:mid,s:" L",i:long,s:"\n");}

    switch (attack)
    {
        case 0:
            b_enemyAttacking(1);
            b_attackPass(0,0); delay(short);
            b_attackPass(3,0); delay(short);
            b_attackPass(6,0); delay(short);
            b_attackPass(7,0); delay(short);
            b_attackPass(4,0); delay(short);
            b_attackPass(1,0); delay(short);
            b_attackPass(2,0); delay(short);
            b_attackPass(5,0); delay(short);
            b_attackPass(8,0); delay(short);
            Delay(mid+getRNG()%11);
            b_attackPass(8,0); delay(short);
            b_attackPass(7,0); delay(short);
            b_attackPass(6,0); delay(short);
            b_attackPass(3,0); delay(short);
            b_attackPass(4,0); delay(short);
            b_attackPass(5,0); delay(short);
            b_attackPass(2,0); delay(short);
            b_attackPass(1,0); delay(short);
            b_attackPass(0,0);
            break;

        case 1:
            b_enemyAttacking(1);
            b_attackGrid(bATK_COL_L); Delay(mid*2);
            b_attackGrid(bATK_COL_M);
            b_attackGrid(bATK_COL_R); Delay(mid*2);
            b_attackGrid(bATK_COL_R); Delay(mid*2);
            b_attackGrid(bATK_COL_M);
            b_attackGrid(bATK_COL_L);
            break;

        case 2:
            b_enemyAttacking(1);
            b_attackGrid(bATK_ROW_U); Delay(mid*2);
            b_attackGrid(bATK_ROW_M);
            b_attackGrid(bATK_ROW_B); Delay(mid*2);
            b_attackGrid(bATK_ROW_B); Delay(mid*2);
            b_attackGrid(bATK_ROW_M);
            b_attackGrid(bATK_ROW_U);
            break;

        case 3:
            b_enemyAttacking(1);
            b_attackPass(1,0); delay(short);
            b_attackPass(1,0); delay(short);
            b_attackPass(1,0); delay(24+vHardMode);
            b_attackPass(0,0);
            b_attackPass(2,0);
            b_attackPass(3,0);
            b_attackPass(4,0);
            b_attackPass(5,0);
            b_attackPass(6,0);
            b_attackPass(7,0);
            b_attackPass(8,0); delay(24+vHardMode);
            b_attackGrid(bATK_O); Delay(24+vHardMode);
            b_attackPass(0,0);
            b_attackPass(1,0);
            b_attackPass(2,0);
            b_attackPass(3,0);
            b_attackPass(4,0);
            b_attackPass(5,0);
            b_attackPass(6,0);
            b_attackPass(8,0);
            break;
    }
    b_enemyAttacking(0);
    Delay(long);
    Restart;
}

