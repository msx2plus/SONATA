script "b_attackPatterns132" (void) // MOONGUARD
{
    b_enemyAttacking(0);
    int shortest = (vHardMode == 2 ? 6 : 4+vHardMode);
    int short = (vHardMode == 2 ? 9 : 6+vHardMode);
    int mid = 20+vHardMode;
    int long = getRNG()%30+30+vHardMode;
    int attack = getRNG()%4;
    if (debugger) {debugMessage = strParam(s:"S",i:short,s:" M",i:mid,s:" L",i:long,s:"\n");}

    switch (attack)
    {
        case 0:
            b_enemyAttacking(1);
            b_attackPass(7,0); delay(shortest);
            b_attackPass(4,0); delay(shortest);
            b_attackPass(1,0); delay(14+vHardMode);
            PlaySound(0,"RPGEXPL",3,0.7);
            b_attackPass(1,15); delay(short);
            b_attackPass(0,15);
            b_attackPass(2,15);
            b_attackPass(4,15); delay(short);
            b_attackPass(3,15);
            b_attackPass(5,15);
            b_attackPass(7,15); delay(short);
            break;

        case 1:
            b_enemyAttacking(1);
            b_attackPass(2,0); delay(shortest);
            b_attackPass(4,0); delay(shortest);
            b_attackPass(6,0); delay(14+vHardMode);
            PlaySound(0,"RPGEXPL",3,0.7);
            b_attackPass(6,15); delay(short);
            b_attackPass(3,15);
            b_attackPass(7,15); delay(short);
            b_attackPass(0,15);
            b_attackPass(4,15);
            b_attackPass(8,15); delay(short);
            b_attackPass(1,15);
            b_attackPass(5,15);
            break;

        case 2:
            b_enemyAttacking(1);
            b_attackPass(0,0); delay(shortest);
            b_attackPass(4,0); delay(shortest);
            b_attackPass(8,0); delay(14+vHardMode);
            PlaySound(0,"RPGEXPL",3,0.7);
            b_attackPass(8,15); delay(short);
            b_attackPass(7,15);
            b_attackPass(5,15); delay(short);
            b_attackPass(2,15);
            b_attackPass(4,15);
            b_attackPass(6,15); delay(short);
            b_attackPass(1,15);
            b_attackPass(3,15);
            break;

        case 3:
            b_enemyAttacking(1);
            b_attackPass(1,0); delay(shortest);
            b_attackPass(4,0); delay(shortest);
            b_attackPass(7,0); delay(14+vHardMode);
