script "b_attackpatterns192" (void) // FLY
{
    b_enemyAttacking(0);
    int i = 0;
    int h1 = 0;
    int h2 = 0;
    int h3 = 0;
    int step = 0;
    int short = (vHardMode == 2 ? 7 : 4+vHardMode);
    int mid = 14+vHardMode;
    int long = getRNG()%20+40+vHardMode;
    int attack = getRNG()%3;
    if (debugger) {debugMessage = strParam(s:"S",i:short,s:" M",i:mid,s:" L",i:long,s:"\n");}

    switch (attack)
    {
        case 0:
            b_enemyAttacking(1);
            step = (getRNG()%8)+1;
            h1 = getRNG()%9;
            h2 = (h1+step)%9;
            b_attackPass(h1,40); b_attackPass(h2,40); delay(mid);
            for (i = 0; i < 3; i++)
            {
                for (int j = 0; j < 4; j++)
                {
                    b_attackPass(bElphPos,0); Delay(5+vHardMode);
                }
            Delay(mid);
            }
            break;

        case 1:
            b_enemyAttacking(1);
            h1 = getRNG()%9;
            step = (getRNG()%8)+1;
            if (step == 3 || step == 6) {step++;}
            for (i = 0; i < 17; i++)
            {
                b_attackPass(h1,0); delay(4+vHardMode);
                h1 = (h1+step)%9;
            }
            break;

        case 2:
            b_enemyAttacking(1);
            h1 = getRNG()%9;
            step = (getRNG()%8)+1;
            if (step == 3 || step == 6) {step++;}
            for (i = 0; i < 15; i++)
            {
                b_attackPass(h1,0); delay((i%3 == 2 ? 16 : 0));
                h1 = (h1+step)%9;
            }
            break;
    }
    b_enemyAttacking(0);
	Delay(long);
    Restart;
}

script "b_attackPatterns204" (void) // PAINFRAME
{
    b_enemyAttacking(0);
