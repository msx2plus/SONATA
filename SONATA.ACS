script "mainInput" ENTER
{
    while(1)
    {
        inputUse =
        ((GetPlayerInput(0,INPUT_BUTTONS) & BT_USE) && !(GetPlayerInput(0,INPUT_OLDBUTTONS) & BT_USE))
        || ((GetPlayerInput(0,INPUT_BUTTONS) & BT_SNUSE) && !(GetPlayerInput(0,INPUT_OLDBUTTONS) & BT_SNUSE));

        inputUp =
        ((GetPlayerInput(0,INPUT_BUTTONS) & BT_FORWARD) && !(GetPlayerInput(0,INPUT_OLDBUTTONS) & BT_FORWARD))
        || ((GetPlayerInput(0,INPUT_BUTTONS) & BT_SNUP) && !(GetPlayerInput(0,INPUT_OLDBUTTONS) & BT_SNUP));

        inputDown =
        ((GetPlayerInput(0,INPUT_BUTTONS) & BT_BACK) && !(GetPlayerInput(0,INPUT_OLDBUTTONS) & BT_BACK))
        || ((GetPlayerInput(0,INPUT_BUTTONS) & BT_SNDOWN) && !(GetPlayerInput(0,INPUT_OLDBUTTONS) & BT_SNDOWN));

        inputLeft =
        ((GetPlayerInput(0,INPUT_BUTTONS) & BT_MOVELEFT) && !(GetPlayerInput(0,INPUT_OLDBUTTONS) & BT_MOVELEFT))
        || ((GetPlayerInput(0,INPUT_BUTTONS) & BT_SNLEFT) && !(GetPlayerInput(0,INPUT_OLDBUTTONS) & BT_SNLEFT));

        inputRight =
        ((GetPlayerInput(0,INPUT_BUTTONS) & BT_MOVERIGHT) && !(GetPlayerInput(0,INPUT_OLDBUTTONS) & BT_MOVERIGHT))
        || ((GetPlayerInput(0,INPUT_BUTTONS) & BT_SNRIGHT) && !(GetPlayerInput(0,INPUT_OLDBUTTONS) & BT_SNRIGHT));

        inputUpHold =
        ((GetPlayerInput(0,INPUT_BUTTONS) & BT_FORWARD))
        || ((GetPlayerInput(0,INPUT_BUTTONS) & BT_SNUP));

        inputDownHold =
        ((GetPlayerInput(0,INPUT_BUTTONS) & BT_BACK))
        || ((GetPlayerInput(0,INPUT_BUTTONS) & BT_SNDOWN));

        inputLeftHold =
        ((GetPlayerInput(0,INPUT_BUTTONS) & BT_MOVELEFT))
        || ((GetPlayerInput(0,INPUT_BUTTONS) & BT_SNLEFT));

        inputRightHold =
        ((GetPlayerInput(0,INPUT_BUTTONS) & BT_MOVERIGHT))
        || ((GetPlayerInput(0,INPUT_BUTTONS) & BT_SNRIGHT));

        Delay(1);
    }
}

script "rpg_debugger" (void)
{
    str input1 = "";
    str input2 = "";
    str input3 = "";
    str input4 = "";
    str input5 = "";
    str debugInfo = "";
    str debugInfo2 = "";
    while (debugger)
    {
    if (!bSafetyCheck)
    {
        debugInfo =
        StrParam(
            s:"ROOM ",i:vCurrentScreen,s:" \n",
            s:"POSX ",i:vPosX,s:".",i:vTweenX*TWEEN_MULT,s:" \n",
            s:"POSY ",i:vPosY,s:".",i:vTweenY*TWEEN_MULT,s:" \n",
            s:"REAL ",i:vRealPos,s:" \n",
            s:"WISH ",i:vWishPos,s:" \n",
            s:"CTRL ",b:vHasControl,s:" \n",
            s:"RNGV ",i:RNG[RNGcount],s:" \n",
            s:"RNGN ",i:RNG[RNGcount+1%64],s:" \n",
            s:"RNGS ",i:RNGcount,s:" \n",
            s:"IN_P ",s:debugMessageInput,s:"\n",
            s:"IN_R ",s:debugMessageRealInput,s:"\n",
            s:"STEP ",i:vStepCount,s:"\n",
            s:"NME1 ",i:areaEncounters[0],s:"\n",
            s:"NME2 ",i:areaEncounters[1],s:"\n",
            s:"USED ",s:debugInteract,s:" \n",
            s:"MODP ",i:vLastMusic,s:" \n",
            s:"TIME ",i:sonataTime
        );
        debugInfo2 = StrParam(s:"\n",s:debugMessage,s:debugMessage2,s:debugMessage3);
    }
    if (bSafetyCheck)
    {
        debugInfo =
        StrParam(
            s:"TYPE ",i:bEnemyType,s:" \n",
            s:"REAL ",i:bElphPos,s:" \n",
            s:"HURT ",b:bElphHurt,s:" \n",
            s:"MOVE ",b:bMoved,s:" \n",
            s:"ATBV ",i:bATBvalue,s:"\n",
            s:"ATB1 ",b:bATBactive,s:"\n",
            s:"RNGV ",i:RNG[RNGcount],s:" \n",
            s:"RNGN ",i:RNG[RNGcount+1%64],s:" \n",
            s:"RNGS ",i:RNGcount,s:" \n",
            s:"CTRL ",b:bHasControl,s:"\n",
            s:"NMEY ",i:bYOffset,s:" \n",
            s:"NMEX ",i:bXOffset,s:" \n",
            s:"MODP ",i:enemyDB[bEnemyType+7],s:":",i:enemyDB[bEnemyType+8],s:" \n",
            s:"TIME ",i:sonataTime
        );
        debugInfo2 = StrParam(s:debugMessage,s:debugMessage2,s:debugMessage3);
    }
    draw("UNSCII",debugInfo,UI_DEBUG,8.1,248.2);
    draw("UNSCII",debugInfo2,UI_DEBUG2,8.1,40.1);
    draw("RPGPOSW","A",UI_DEBUGWISH,(((vWishPos%20)*16)<<16)+0.1,(((vWishPos/20)*16)<<16)+32.1);
    draw("RPGPOSR","A",UI_DEBUGREAL,((vPosX*16)<<16)+0.1,((vPosY*16)<<16)+32.1);

    // input display
    if (inputRightHold) {input1 = "R";} else {input1 = "";}
    if (inputLeftHold) {input2 = "L";} else {input2 = "";}
    if (inputUpHold) {input3 = "U";} else {input3 = "";}
    if (inputDownHold) {input4 = "D";} else {input4 = "";}
    if (inputUse) {input5 = "1";} else {input5 = "";}
    debugMessageRealInput = strParam(s:input1,s:input2,s:input3,s:input4,s:input5);
    Delay(1);
    }
    clear(UI_DEBUG);
    clear(UI_DEBUG2);
    clear(UI_DEBUG3);
    clear(UI_DEBUGWISH);
    clear(UI_DEBUGREAL);
}

script "sonataTimer" (void)
{
    sonataTime = 0;
    while (1)
    {
        sonataTime++;
        Delay(1);
    }
}

script "sonataTimeDsiplay" (void)
{
    while (1)
    {
    int sTimeS = sonataTime/35;
    int sTimeSec = sTimeS % 60;
    int sTimeMin = (sTimeS / 60) % 60;
    int sTimeHr = sTimeS / 3600;
    sonataTimeDisplay = strParam(i:sTimeHr/10,i:sTimeHr%10,s:":",i:sTimeMin/10,i:sTimeMin%10,s:":",i:sTimeSec/10,i:sTimeSec%10);
    if (drawTime) {drawHud();}
    Delay(35);
    }
}

script "rpg_Starter" ENTER
{
    killCount =
        (
            GetCvar("shroKills") +
            GetCvar("abutKills") +
            GetCvar("akasKills") +
            GetCvar("beasKills") +
            GetCvar("beliKills") +
            GetCvar("blooKills") +
            GetCvar("commKills") +
            GetCvar("demoKills") +
            GetCvar("direKills") +
            GetCvar("drauKills") +
            GetCvar("moonKills") +
            GetCvar("follKills") +
            GetCvar("flesKills") +
            GetCvar("railKills") +
            GetCvar("gargKills") +
            GetCvar("growKills") +
            GetCvar("hellKills") +
            GetCvar("lunaKills") +
            GetCvar("maliKills") +
            GetCvar("procKills") +
            GetCvar("sentKills") +
            GetCvar("wallKills") +
            GetCvar("watcKills") +
            GetCvar("zealKills") +
            GetCvar("nitrKills")
        ) / 500;
    killCount = killCount > 10 ? 10 : killCount;
    AmbientSound("FDSON",127);
    PlaySound(0,"LINENOIS",7,1.0,TRUE);
    FadeTo(0,0,0,1.0,0.0);
    SetPlayerProperty(0,1,PROP_TOTALLYFROZEN);
    Delay(1);
    ScriptCall("postProcKiller","postProcOff");
    ScriptCall("postProcKiller","NTSCOn");
	setRes();
    SetFont("RPGSTAT0");
    HudMessage(s:"A";HUDMSG_PLAIN|HUDMSG_ALPHA|HUDMSG_LAYER_OVERHUD,UI_STATIC,CR_UNTRANSLATED,160.0,128.0,0,0.01);
	SetFont("RPGBRDR");
	HudMessage(s:"A";HUDMSG_PLAIN|HUDMSG_LAYER_OVERHUD,UI_BORDER,CR_UNTRANSLATED,0.2,0.1,0);
	SetFont("RPGBRDR");
	HudMessage(s:"A";HUDMSG_PLAIN|HUDMSG_LAYER_OVERHUD,UI_BORDER+1,CR_UNTRANSLATED,320.1,0.1,0);
	ACS_NamedExecute("titleMenu",0);
}

function void reInit (void)
{
    vPosX = 12;
    vPosY = 8;
    vTweenX = 0;
    vTweenY = 0;
    vRealPos = 0;
    vCurrentScreen = 10;
    vTriedUse = 0;
    vHP = 40;
    vLastMusic = 0;
    vLastMusicFile = 0;
    vSanityTimer = 0;
    vStepCount = 0;
    vTweening = 0;

    vWishPos = 0;

    vAnim = 0;
    vHasControl = 0;

    debugger = 0;

    debugInteract = "";
    debugMessage = "";
    debugMessage2 = "";
    debugMessage3 = "";
    debugMessageInput = "";
    debugMessageRealInput = "";
    strRpgVersion = "";
    vRpgVersion = 1;

    drawTime = 0;

    battlesOn = 1;
    battleMusicSwitch = 1;
    boss1Clear = 0;
    boss2Clear = 0;
    boss3Clear = 0;
    boss4Clear = 0;
    altBoss1Clear = 0;
    altBoss2Clear = 0;
    vPowerSpeed = 0;
    key1Got = 0;
    key2Got = 0;
    key3Got = 0;
    sprite1At = 0;
    sprite2At = 0;
    sprite3At = 0;
    RNGcount = 0;

    unlocked1 = 0;
    unlocked2 = 0;
    unlocked3 = 0;

    TWEEN_SPEED = 4;
    TWEEN_MULT = 4;
    MOVE_DELAY = 3;

    vBowBoost = 0;
    vMeleeBoost = 0;
    vHasBomb = 0;
    vHasPotion = 0;
    vHasTeleport = 0;
    vHasSlowSlots = 0;
    vHasBook = 0;

    sonataTime = 0;

    vStep1 = "RPGSTEP2";
    vStep2 = "RPGSTEP3";

    vGold = 0;

    vOpenedDebug = 0;
}

function void debugGive (void)
{
    boss1Clear = 1;
    boss2Clear = 1;
    boss3Clear = 1;
    boss4Clear = 1;
    key1Got = 1;
    key2Got = 1;
    key3Got = 1;
    altBoss1Clear = 1;
    altBoss2Clear = 1;
    vStep1 = "RPGSK81";
    vStep2 = "RPGSK82";
    TWEEN_SPEED = 2;
    TWEEN_MULT = 8;
    MOVE_DELAY = 1;
    vBowBoost = 2;
    vMeleeBoost = 2;
    vHasBomb = 1;
    vHasPotion = 1;
    vHasTeleport = 9;
    vHasSlowSlots = 1;
    vHasBook = 1;
}

function void getVersion (void)
{
    str gotWest = "0";
    str gotEast = "0";
    str gotSouth = "0";
    if (GetCvar("diskEast")) {vRpgVersion++; gotEast = "E";}
    if (GetCvar("diskWest")) {vRpgVersion++; gotWest = "W";}
    if (GetCvar("diskSouth")) {vRpgVersion++; gotSouth = "S";}
    if (GetCvar("diskDebug")) {vRpgVersion++;}
    strRpgVersion = StrParam(s:"\c[FamiGrey]Ver0.",d:vRpgVersion,s:(GetCvar("diskDebug") ? "\c[FamiRed]DEBUG" : strParam(s:gotWest,s:gotSouth,s:gotEast)));
}

function bool diskCheck (int diskType)
{
    bool diskBool = 0;
    if (diskType == DISK_EAST) {diskBool = GetCvar("diskEast");}
    if (diskType == DISK_WEST) {diskBool = GetCvar("diskWest");}
    if (diskType == DISK_SOUTH) {diskBool = GetCvar("diskSouth");}
    if (diskType == DISK_ATTACKS) {diskBool = GetCvar("diskAttack");}
    if (diskType == DISK_ITEMS) {diskBool = GetCvar("diskItems");}
    if (diskType == DISK_DEBUG) {diskBool = GetCvar("diskDebug");}
    return diskBool;
}

function void setRes (void)
{
    SetHudSize(320,256,TRUE);
}

function void draw (str fontname, str string, int zone, int posX, int posY)
{
    setRes();
    SetFont(fontname);
    HudMessage(s:string;HUDMSG_PLAIN|HUDMSG_LAYER_OVERHUD,zone,CR_UNTRANSLATED,posX,posY,0);
}

function void clear (int zone)
{
    HudMessage(s:"";HUDMSG_PLAIN,zone,CR_UNTRANSLATED,0.0,0.0,1873);
}

function void clearAll (void)
{
    clear(ZONE_BG);
    clear(ZONE_SPRITE1);
    clear(ZONE_SPRITE2);
    clear(ZONE_SPRITE3);
    clear(ZONE_ROOM);
    clear(ZONE_ELPH);
    clear(UI_BOX);
    clear(UI_PORTBOX);
    clear(UI_TEXT);
    clear(UI_PORT);
    clear(UI_HUDFACE);
    clear(UI_HUDKEY1);
    clear(UI_HUDKEY2);
    clear(UI_HUDKEY3);
    clear(UI_HUDKEY3);
    clear(UI_HUDSKATE);
    clear(UI_HUDBAND);
    clear(UI_HUDBOOK);
    clear(UI_HUDROOMNAME);
    clear(UI_HUDBAR);
    clear(UI_MENU);
    clear(UI_MENUTEXT);
    clear(UI_MENUINFO);
    clear(UI_MENUSELECTOR);
    clear(BATTLE_SLOT);
}

function void drawHud (void)
{
    draw("RPGHUD","A",UI_HUDBAR,0.1,0.1);
    //draw(vExpression,"A",UI_HUDFACE,0.1,0.1);
    draw("UNSCII",strParam(s:"MIND: ",i:(vHP < 0 ? 0 : vHP),s:"/40\nGOLD: ",i:vGold,s:"\n",s:sonataTimeDisplay),UI_HUDROOMNAME,4.1,4.1);
    if (key1Got) {draw("RPGKEY1","A",UI_HUDKEY1,235.1,7.1);}
    if (key2Got) {draw("RPGKEY2","A",UI_HUDKEY2,265.1,7.1);}
    if (key3Got) {draw("RPGKEY3","A",UI_HUDKEY3,295.1,7.1);}
    if (altboss1Clear) {draw("RPGSKATE","A",UI_HUDSKATE,205.1,7.1);}
    if (altboss2Clear) {draw((vPowerSpeed == 0 ? "RPGBANDP" : "RPGBANDS"),"A",UI_HUDBAND,175.1,7.1);}
    if (vHasBook) {draw("RPGBOOK","A",UI_HUDBOOK,145.1,7.1);}
}

function void drawSprite (int tile, str sprite, int zone)
{
    tile = tile;
    int tileX = tile%20;
    int tileY = tile/20;
    draw(SPRITE,"A",zone,0.1+((tileX*16)<<16),32.1+((tileY*16)<<16));
}

function void drawElph (void)
{
    if (Timer()%6 == 0)
    {
        vAnim = !vAnim;
    }

    draw(strParam(s:"RPGELPH",i:vAnim+1),"A",ZONE_ELPH,((vPosX*16)+(vTweenX*TWEEN_MULT)<<16)+0.1,((vPosY*16)+(vTweenY*TWEEN_MULT)<<16)+32.1);
}

function void interact (int checkXY, int checkRoom)
{
    // general cases
    for (int i = 0 ; i < INTERACTION_ARRAY_SIZE/4 ; i++)
    {
        if (checkRoom == interactionDB[i*4])
        {
            if (checkXY == interactionDB[(i*4)+1])
            {
                if (interactionDB[(i*4)+3] != 0)
                {
                    if (vteleportBufferTime <= 0)
                    {
                        if (checkRoom != ROOM_E || GetCvar("diskDebug") == 1)
                        {
                            ACS_NamedExecute("roomChange",0,interactionDB[(i*4)+2],interactionDB[(i*4)+3]);
                            ACS_NamedExecute("teleportBuffer",0);
                        }
                    }
                    break;
                }
                else
                {
                    if (interactionDB[(i*4)+2] == INT_MSX) {vHasBomb = 1; vHasPotion = 1;}
                    ACS_NamedExecute("interactObject",0,interactionDB[(i*4)+2]);
                    break;
                }
            }
        }
    }

    // special cases
    switch (checkRoom)
    {
        case ROOM_HOMEMOON:
        switch (checkXY)
        {
            case EXIT_HOMEMOON_EXIT:
            ACS_NamedExecute("roomChange",0,ROOM_HOMEHALL,ENTER_HOMEHALL_FROMMOON);
            ACS_NamedTerminate("sanity",0);
            break;
        }
    }
}

function void textBox (bool drawClear, int drawType, str portType)
{
    if (drawClear)
    {
        vHasControl = 0;
        if (drawType == INT_OBJ)
        {
            draw("RPGTBOX","A",UI_BOX,48.1,144.1);
        }
        if (drawType == INT_NPC)
        {
            draw("RPGTBOX","A",UI_BOX,68.1,144.1);
            draw("RPGPBOX","A",UI_PORTBOX,28.1,152.1);
            draw(portType,"A",UI_PORT,36.1,160.1);
        }
    }
    else
    {
        vHasControl = 1;
        clear(UI_TEXT);
        clear(UI_BOX);
        clear(UI_PORTBOX);
        clear(UI_PORT);
    }
}

function void moveElph (int direction)
{
    getElphReal();

    if (vHasControl)
    {
        Switch (direction)
        {
            Case 1:
            vWishPos = vRealPos+1;
            if (screenDB[vCurrentScreen][vWishPos] == 0) {vTriedUse = 1;}
            if (screenDB[vCurrentScreen][vWishPos] == 1 || vPosX == 19 || GetCvar("debugMode")) {vPosX++; vTweenX -= TWEEN_SPEED; vTriedUse = 0; PlaySound(0,(vStepCount%2 == 0 ? vStep1 : vStep2),4);}
            if (screenDB[vCurrentScreen][vWishPos] == 2) {interact(vWishPos,vCurrentScreen); vTriedUse = 2;}
            Break;

            Case 2:
            vWishPos = vRealPos-1;
            if (screenDB[vCurrentScreen][vWishPos] == 0) {vTriedUse = 1;}
            if (screenDB[vCurrentScreen][vWishPos] == 1 || vPosX == 0 || GetCvar("debugMode")) {vPosX--; vTweenX += TWEEN_SPEED; vTriedUse = 0; PlaySound(0,(vStepCount%2 == 0 ? vStep1 : vStep2),4);}
            if (screenDB[vCurrentScreen][vWishPos] == 2) {interact(vWishPos,vCurrentScreen); vTriedUse = 2;}
            Break;

            Case 3:
            vWishPos = vRealPos+20;
            if (screenDB[vCurrentScreen][vWishPos] == 0) {vTriedUse = 1;}
            if (screenDB[vCurrentScreen][vWishPos] == 1 || vPosY == 13 || GetCvar("debugMode")) {vPosY++; vTweenY -= TWEEN_SPEED; vTriedUse = 0; PlaySound(0,(vStepCount%2 == 0 ? vStep1 : vStep2),4);}
            if (screenDB[vCurrentScreen][vWishPos] == 2) {interact(vWishPos,vCurrentScreen); vTriedUse = 2;}
            Break;

            Case 4:
            vWishPos = vRealPos-20;
            if (screenDB[vCurrentScreen][vWishPos] == 0) {vTriedUse = 1;}
            if (screenDB[vCurrentScreen][vWishPos] == 1 || vPosY == 0 || GetCvar("debugMode")) {vPosY--; vTweenY += TWEEN_SPEED; vTriedUse = 0; PlaySound(0,(vStepCount%2 == 0 ? vStep1 : vStep2),4);}
            if (screenDB[vCurrentScreen][vWishPos] == 2) {interact(vWishPos,vCurrentScreen); vTriedUse = 2;}
            Break;
        }

        if (vTriedUse == 0 && vPosX < 18 && vPosX > 1 && vPosY < 12 && vPosY > 1)
        {
            vStepCount++;
            vStepCount = vStepCount%128;
        }

		if (vStepCount > 116 && getRNG()%4 == 0 && vPosX < 19 && vPosX > 0 && vPosY < 13 && vPosY > 0 && vTrieduse == 0)
		{
		    int eCheck = areaEncounters[getRNG()%2];
			if ((echeck != 99 || (eCheck == bENEMY_ATLAS && !atlasDone)) && battlesOn)
			{
				ACS_NamedExecute("b_initBattle",0,eCheck);
			}
		}

        if (debugger)
        {
            if (vTriedUse == 2) {debugInteract = strparam(s:"R", i:vCurrentScreen, s:" T", i:vWishPos);}
            else if (vTriedUse == 1) {debugInteract = "WALL";}
            else {debugInteract = "NONE";}
        }

	if (vPosX > 19 && vCurrentScreen < 143) {ACS_NamedExecute("roomChange",0,vCurrentScreen+1,vPosY*20);}
	if (vPosX < 0 && vCurrentScreen > 0) {ACS_NamedExecute("roomChange",0,vCurrentScreen-1,(vPosY*20)+19);}
	if (vPosY > 13 && vCurrentScreen < 131) {ACS_NamedExecute("roomChange",0,vCurrentScreen+12,vPosX);}
    if (vPosY < 0 && vCurrentScreen > 11) {ACS_NamedExecute("roomChange",0,vCurrentScreen-12,vPosX+260);}
    }

    getElphReal();
    if (GetCvar("debugMode")) {getElphReal(); log(s:"R",i:vCurrentScreen,s:" T",i:vRealPos);}
    if (!bSafetyCheck) {drawElph();}

    // ITEM COLLECTION, OTHER SPECIAL CASES
    if (vCurrentScreen == ROOM_CROSSING && vWishPos == OBJ_CROSSING_SHOP)
    {
        ACS_NamedExecute("shopping",0);
        PlaySound(0,"RPGRUN",2);
    }
    if (vCurrentScreen == ROOM_STAR_MAZE_KEY)
    {
        if (vHasBook == 0 && (vPosX + (vPosY*20)) == sprite1At)
        {
            clear(ZONE_SPRITE1); vHasBook = 1; AmbientSound("RPGKEY",127); drawHUD();
        }
    }
    if (vCurrentScreen == ROOM_PAINFRAME)
    {
        if (key2Got == 0 && (vPosX + (vPosY*20)) == sprite1At)
        {
            clear(ZONE_SPRITE1); key2Got = 1; AmbientSound("RPGKEY",127); drawHUD();
        }
    }
    if (vCurrentScreen == ROOM_TOWERBASEMENT)
    {
        if (key3Got == 0 && (vPosX + (vPosY*20)) == sprite1At)
        {
            clear(ZONE_SPRITE1); key3Got = 1; AmbientSound("RPGKEY",127); drawHUD();
        }
    }
    if (vCurrentScreen == ROOM_POSTGUTS2 && key1Got == 0 && (vPosX + (vPosY*20)) == sprite1At) {clear(ZONE_SPRITE1); key1Got = 1; AmbientSound("RPGKEY",127); drawHUD();}
    if (vCurrentScreen == ROOM_FLY && altBoss2Clear == 0 && vPosY < 7) {ACS_NamedExecute("b_initBattle",0,bENEMY_FLY);}
    if (vCurrentScreen == ROOM_KEYS)
    {
        if (key1Got == 1 && unlocked1 == 0 && vWishPos == 122)
        {
            ACS_NamedExecuteAlways("keyUnlock",0,122,ZONE_SPRITE1);
            clear(UI_HUDKEY1);
            unlocked1 = 1;
            key1Got = 0;
        }
        if (key2Got == 1 && unlocked2 == 0 && vWishPos == 49)
        {
            ACS_NamedExecuteAlways("keyUnlock",0,49,ZONE_SPRITE2);
            clear(UI_HUDKEY2);
            unlocked2 = 1;
            key2Got = 0;
        }
        if (key3Got == 1 && unlocked3 == 0 && vWishPos == 136)
        {
            ACS_NamedExecuteAlways("keyUnlock",0,136,ZONE_SPRITE3);
            clear(UI_HUDKEY3);
            unlocked3 = 1;
            key3Got = 0;
        }
    }
}

script "diskSide" (int entry)
{
    bool hadControl = 0;
    if (vHasControl) {hadControl = 1; vHasControl = 0;}
    SetMusic("");
    clearAll();
    Delay(5);
    if (diskSide != loadArray[entry+2])
    {
        draw("UNSCII",strParam(s:"SET SIDE ",s:(loadArray[entry+2] == 0 ? "A" : "B")),50,160.0,112.2);
        while (diskSide != loadArray[entry+2])
        {
            Delay(15);
        }
    }
    clearAll();
    Delay(5);
    AmbientSound("DISKREAD",127);
    draw("UNSCII","WAIT A MOMENT",50,160.0,112.2);
    Delay(125);
    clearAll();
    Delay(10);
    if (hadControl) {hadControl = 0; vHasControl = 1;}
}

script "keyUnlock" (int tile, int zone)
{
    PlaySound(0,"RPGBMEL",1);
    drawSprite(tile-21,"RPGBFX4",zone);Delay(2);
    drawSprite(tile-42,"RPGBFX5",zone);Delay(2);
    drawSprite(tile-42,"RPGBFX6",zone);Delay(3);
    drawSprite(tile-42,"RPGBFX7",zone);Delay(3);
    clear(zone);
    drawHud();

    if (unlocked1 && unlocked2 && unlocked3)
    {
        ACS_NamedExecute("roomChange",0,ROOM_KEYS_OPEN,vRealPos);
    }
}

function void getElphReal (void)
{
    vRealPos = vPosX + (vPosY*20);
}

function void getElphXY (void)
{
    vPosX = vRealPos%20;
    vPosY = vRealPos/20;
}

function void changeBGM (str musicName, int unused, bool remember)
{
    if (musicName == BGM_NONE || (vCurrentScreen == ROOM_PAINFRAME && boss2Clear)|| (vCurrentScreen == ROOM_STAR_MAZE_D && boss4clear))
    {
        SetMusic("");
    }
    else
    {
        SetMusic("D_SNT",musicName);
    }
	if (remember)
	{
		vLastMusic = musicName;
		vLastMusicFile = unused;
	}
}

function void drawRoom(bool buffered)
{
    if (!buffered)
    {
    // CHECK BOSS 1 CLEAR
    if (vCurrentScreen == ROOM_PROTECTORS && boss1Clear) {vCurrentScreen = ROOM_POSTGUTS;}
    if (vCurrentScreen == ROOM_STAR_MAZE_D && boss4Clear) {vCurrentScreen = ROOM_STAR_MAZE_POST;}
    if (vCurrentScreen == ROOM_KEYS && unlocked1 && unlocked2 && unlocked3) {vCurrentScreen = ROOM_KEYS_OPEN;}

    // SPRITES
    switch (vCurrentScreen)
    {
        case ROOM_POSTGUTS2:
        if (key1Got == 0 && unlocked1 == 0) {drawSprite(130,"RPGKEY1",ZONE_SPRITE1); sprite1At = 130;}
        break;

        case ROOM_STAR_MAZE_KEY:
        if (vHasBook == 0) {drawSprite(149,"RPGBOOK",ZONE_SPRITE1); sprite1At = 149;}
        break;

        case ROOM_LTQ:
        drawSprite(OBJ_LTQ,"RPGLTQS",ZONE_SPRITE1); sprite1At = OBJ_LTQ;
        break;

        case 120:
        drawSprite(72,"RPGTUNLS",ZONE_SPRITE1); sprite1At = 72;
        break;

        case ROOM_STAR_MAZE_D:
        if (!boss4Clear) {drawSprite(89,"RPGEYE",ZONE_SPRITE1); sprite1At = 89;}
        break;

        case ROOM_TOWERBASEMENT:
        if (boss3Clear && key3Got == 0 && unlocked3 == 0) {drawSprite(170,"RPGKEY3",ZONE_SPRITE1); sprite1At = 170;}
        break;

        case ROOM_PAINFRAME:
        if (!boss2Clear) {drawSprite(127,"RPGCOMP1",ZONE_SPRITE1); sprite1At = 127;}
        else if (boss2Clear && key2Got == 0 && unlocked2 == 0) {drawSprite(125,"RPGKEY2",ZONE_SPRITE1); sprite1At = 125;}
        break;

        case ROOM_KEYS:
        if (unlocked1 == 0) {drawSprite(122,"RPGKEYH1",ZONE_SPRITE1); sprite1At = 130;}
        if (unlocked2 == 0) {drawSprite(49,"RPGKEYH2",ZONE_SPRITE2); sprite2At = 130;}
        if (unlocked3 == 0) {drawSprite(136,"RPGKEYH3",ZONE_SPRITE3); sprite3At = 130;}
        break;

        default:
        sprite1At = 0;
        sprite2At = 0;
        sprite3At = 0;
    }

    vSanityTimer = 0;
    ACS_NamedTerminate("sanity",0);
    debugMessage = "";
    debugMessage2 = "";
    debugMessage3 = "";

    // special cases
    switch (vCurrentScreen)
    {
        case 111:
        case 112:
        case ROOM_PAINFRAME:
        case ROOM_SOUTH_COMPUTER:
            draw("SBG004","A",ZONE_BG,160.0,144.0);
            break;

        case ROOM_KEYS:
        case ROOM_KEYS_OPEN:
        case ROOM_STAR_MAZE_A:
        case ROOM_STAR_MAZE_B:
        case ROOM_STAR_MAZE_C:
        case ROOM_STAR_MAZE_D:
        case ROOM_STAR_MAZE_KEY:
        case ROOM_STAR_MAZE_POST:
            draw("SBG003","A",ZONE_BG,160.0,144.0);
            break;

        case ROOM_WEST_GOINGDOWN:
        case ROOM_HOMEOUTSIDE:
        case ROOM_CROSSING:
        case ROOM_0X3E:
        case ROOM_0X40:
        case ROOM_0X4B:
        case ROOM_WESTWARD:
        case ROOM_EASTWARD:
        case ROOM_SOUTHBOUND:
            draw("SBG001","A",ZONE_BG,160.0,144.0);
            break;

        case 65:
        case 66:
        case 77:
        case 78:
        case 90:
            draw("SBG002","A",ZONE_BG,160.0,144.0);
            break;

        case ROOM_HOMEELPH:
            break;

        case ROOM_HOMEHALL:
            break;
    }

    // room drawing
    ACS_NamedExecute("areaSwitcher",0);
    draw(StrParam(s:"_SRM",i:vCurrentScreen),"A",ZONE_ROOM,160.0,144.0);
    drawHud();
    }

    else
    {
        setRes();
        SetFont(StrParam(s:"_SRM",i:vCurrentScreen));
        HudMessage(s:"A";HUDMSG_PLAIN,ZONE_ROOM,CR_UNTRANSLATED,160.0,-144.0,1873);
    }
}

script "titleMenu" (void)
{
    reInit();
    ACS_NamedTerminate("sonataTimer",0);
    changeBGM(BGM_NONE,2,TRUE);
    setRes();
    getVersion();
    draw("RPGBLSC1","A",50,160.0,128.0);
    Delay(4);
    draw("RPGBLSC2","A",50,160.0,128.0+random(-64,64));
    Delay(1);
    draw("RPGBLSC2","A",50,160.0,128.0+random(-128,128));
    Delay(1);
    Clear(50);
    Delay(10);

    if (!booted)
    {
        changeBGM(BGM_DISK,2,TRUE);
        draw("RPGDD1","A",50,160.0,128.0); Delay(3);
        draw("RPGDD2","A",50,160.0,128.0); Delay(3);
        draw("RPGDD3","A",50,160.0,128.0); Delay(3);
        draw("RPGDD4","A",50,160.0,128.0); Delay(3);
        draw("RPGDD5","A",50,160.0,128.0); Delay(1);
        draw("RPGDD4","A",50,160.0,128.0); Delay(1);
        draw("RPGDD5","A",50,160.0,128.0); Delay(1);
        draw("RPGDD4","A",50,160.0,128.0); Delay(1);
        draw("RPGDD5","A",50,160.0,128.0); Delay(1);
        draw("RPGDD4","A",50,160.0,128.0); Delay(25);
        draw("RPGDD3","A",50,160.0,128.0); Delay(5);
        draw("RPGDD2","A",50,160.0,128.0); Delay(5);
        draw("RPGDD1","A",50,160.0,128.0); Delay(5);
        clear(50);
        booted = 1;
        delay(30);

        debugmessage2 = "SCREEN_SELENESYSTEMS\n";
        draw("RPGHOWL","A",50,160.0,128.0);
        Delay(30);
        debugmessage2 = "";
        clear(50);
        Delay(30);
    }

    changeBGM(BGM_MOONLIGHT,1,TRUE);
    draw("RPGTITLE","A",50,160.0,60.1);
    draw("UNSCII",strRpgVersion,49,268.2,146.1);
    draw("UNSCII",strParam(s:"START\n",s:"COMBAT: ",s:(vHardMode == 2 ? "LIGHT" : (vHardMode == -1 ? "HYPER" : "NORMAL")),s:"\n",s:(GetCVar("diskDebug") ? "TEST MODE\n" : "\c[FamiGrey]...\n"),s:"QUIT\n"),48,104.1,168.1);
    draw("UNSCII",">",47,96.1,168.1);

    debugmessage2 = "SCREEN_TITLE\n";
    bool inMenu = 1;
    int menuOption = 0;

    while (inMenu)
    {
        if (inputDown && menuOption < 3)
        {
            menuOption++;
            PlaySound(0,"RPGMENUS",1);
            draw("UNSCII",">",47,96.1,168.1+((menuOption*8)<<16));
        }

        if (inputUp && menuOption > 0)
        {
            menuOption--;
            PlaySound(0,"RPGMENUS",1);
            draw("UNSCII",">",47,96.1,168.1+((menuOption*8)<<16));
        }

        if (inputUse)
        {
            switch (menuOption)
            {
                case 0:
                    if (diskCheck(DISK_EAST) || diskCheck(DISK_WEST) || diskCheck(DISK_SOUTH) || diskCheck(DISK_DEBUG)) {anyDisks = 1;}
                    PlaySound(0,"RPGMENUO",1);
                    inMenu = 0;
                break;

                case 1:
                    PlaySound(0,"RPGMENUO",1);
                    if (vHardMode == -1) {vHardMode = 2;}
                    else if (vHardMode == 2) {vHardMode = 0;}
                    else if (vHardMode == 0) {vHardMode = -1;}
                    draw("UNSCII",strParam(s:"START\n",s:"COMBAT: ",s:(vHardMode == 2 ? "LIGHT" : (vHardMode == -1 ? "HYPER" : "NORMAL")),s:"\n",s:(GetCVar("diskDebug") ? "TEST MODE\n" : "\c[FamiGrey]...\n"),s:"QUIT\n"),48,104.1,168.1);
                break;

                case 2:
                    if (GetCvar("diskDebug"))
                    {
                        clear(47);
                        clear(48);
                        clear(49);
                        clear(50);
                        PlaySound(0,"RPGMENUO",1);
                        ACS_NamedExecute("soundTest",0);
                        Terminate;
                    }
                break;

                case 3:
                    clear(47);
                    clear(48);
                    clear(49);
                    clear(50);
                    SetMusic("",0);
                    StopSound(0,7);
                    AmbientSound("FDSON",127);
                    Delay(10);
                    ChangeLevel("C2M0",0,CHANGELEVEL_NOINTERMISSION|CHANGELEVEL_RESETHEALTH|CHANGELEVEL_RESETINVENTORY,2);
                break;
            }
        }
        delay(1);
    }

    debugMessageInput = "";

    changeBGM(BGM_NONE,2,TRUE);
    clear(47);
    clear(48);
    clear(49);
    clear(50);


    drawRoom(1);
    Delay(20);
    drawHud();
    drawRoom(0);
    drawElph();
    drawTime = 1;
    vHasControl = 1;
    ACS_NamedExecute("HPtracker",0);
    ACS_NamedExecute("inputHandler",0);
    ACS_NamedExecute("tweenElph",0);
    ACS_NamedExecute("sonataTimer",0);
    ACS_NamedExecute("sonataTimeDsiplay",0);
}

script "soundTest" (void)
{
    changeBGM(BGM_NONE,2,TRUE);
    Delay(10);
    debugmessage = "";
    debugmessage2 = "";
    debugmessage3 = "";
    int stMusicFile = 0;
    int stMusicPattern = 0;
    int stSoundFile = 0;
    int stGraphic = 0;
    int stSelection = 1;
    bool stUpdate = 1;
    bool stUpdateHold = 0;

    draw("RPGCONSP","A",52,16.1,240.2);

    while (1)
    {
    if (inputUp)
    {
        stSelection--;
        stUpdate = 1;
        PlaySound(0,"RPGMENUS",1);
    }
    if (inputDown)
    {
        stSelection++;
        stUpdate = 1;
        PlaySound(0,"RPGMENUS",1);
    }

    if (inputLeft)
    {
        switch (stSelection)
        {
            case 0:
                stMusicFile--;
                stUpdate = 1;
                PlaySound(0,"RPGMENUS",1);
            break;

            case 1:
                stMusicPattern--;
                stUpdate = 1;
                PlaySound(0,"RPGMENUS",1);
            break;

            case 2:
                stSoundFile--;
                stUpdate = 1;
                PlaySound(0,"RPGMENUS",1);
            break;

            case 3:
                stGraphic--;
                stUpdate =1;
                PlaySound(0,"RPGMENUS",1);
            break;
        }
    }

    if (inputRight)
    {
        switch (stSelection)
        {
            case 0:
                stMusicFile++;
                stUpdate = 1;
                PlaySound(0,"RPGMENUS",1);
                break;

            case 1:
                stMusicPattern++;
                stUpdate = 1;
                PlaySound(0,"RPGMENUS",1);
            break;

            case 2:
                stSoundFile++;
                stUpdate = 1;
                PlaySound(0,"RPGMENUS",1);
            break;

            case 3:
                stGraphic++;
                stUpdate =1;
                PlaySound(0,"RPGMENUS",1);
            break;
        }
    }

    if (stGraphic < 0) {stGraphic = bgArrayTotal;}
    if (stGraphic > bgArrayTotal) {stGraphic = 0;}
    if (stSelection < 1) {stSelection = 1;}
    if (stSelection > 4) {stSelection = 4;}
    if (stMusicFile < 0) {stMusicFile = 0;}
    if (stMusicFile > 1) {stMusicFile = 1;}
    if (stMusicPattern < 0 ) {stMusicPattern = musicArray1Total-1;}
    if (stMusicPattern > musicArray1Total-1) {stMusicPattern = 0;}
    if (stSoundFile < 0) {stSoundFile = sfxArrayTotal-1;}
    if (stSoundFile > sfxArrayTotal-1) {stSoundFile = 0;}

    if (stUpdate)
    {
    draw
    (
        "UNSCII",
        strParam
        (
            s:(stSelection == 1 ? ">" : " "), s:"SONG\n",
            s:(stSelection == 2 ? ">" : " "), s:"SFX\n",
            s:(stSelection == 3 ? ">" : " "), s:"GFX\n",
            s:(stSelection == 4 ? ">" : " "), s:"EXIT "
        ),
        50,
        112.1,
        96.1
    );

    draw
    (
        "UNSCII",
        strParam
        (
            s:hexArray[stMusicPattern], s:"\n",
            s:"\c-",s:hexArray[stSoundFile],s:"\n",
            s:"\c-",s:hexArray[stGraphic],s:"\n"
        ),
        51,
        176.1,
        96.1
    );

    draw(bgArray[stGraphic],"A",54,160.0,128.0);

    if (stUpdateHold) {Delay(4); stUpdateHold = 0;}
    stUpdate = 0;
    }

    if (inputUse && (stSelection == 0 || stSelection == 1))
    {
        changeBGM(BGM_NONE,2,TRUE);
        Delay(5);
        changeBGM(musicArray1[stMusicPattern],1,TRUE);
    }
    if (inputUse && stSelection == 2)
    {
        changeBGM(BGM_NONE,2,TRUE);
        PlaySound(0,sfxArray[stSoundFile],1);
    }
    if (inputUse && stSelection == 4)
    {
        clear(50);
        clear(51);
        clear(52);
        clear(53);
        clear(54);
        changeBGM(BGM_NONE,2,TRUE);
        StopSound(0,1);
        PlaySound(0,"RPGMENUO",1);
        Delay(5);
        StopSound(0,1);
        AmbientSound("FDSON",127);
        ACS_NamedExecute("titleMenu",0);
        Terminate;
    }

    Delay(1);
    }
}

script "inputHandler" (void)
{
    while (1)
    {
        if (vHasControl)
        {
            if (inputRightHold)
            {
                debugMessageInput = StrParam(s:"R");
                moveElph(1);
                Delay(MOVE_DELAY);
            }
            if (inputLeftHold)
            {
                debugMessageInput = StrParam(s:"L");
                moveElph(2);
                Delay(MOVE_DELAY);
            }
            if (inputDownHold)
            {
                debugMessageInput = StrParam(s:"D");
                moveElph(3);
                Delay(MOVE_DELAY);
            }
            if (inputUpHold)
            {
                debugMessageInput = StrParam(s:"U");
                moveElph(4);
                Delay(MOVE_DELAY);
            }
        }
        if (inputUse && vHasControl)
            {
                ACS_NamedExecuteWait("inGameMenu",0);
            }
        debugMessageInput = StrParam(s:"-");
        Delay(1);
    }
}

script "tweenElph" (void)
{
    While (vTweenX != 0 || vTweenY != 0)
    {
        vTweening = 1;
        if (vTweenX < 0) {vTweenX+= 1;}
        if (vTweenX > 0) {vTweenX-= 1;}
        if (vTweenY < 0) {vTweenY+= 1;}
        if (vTweenY > 0) {vTweenY-= 1;}
        if (!bSafetyCheck) {drawElph();}
        Delay (1);
    }
    vTweening = 0;
    Delay (1);
    Restart;
}

script "interactObject" (int intArrayFetch)
{
    if (vHasControl)
    {
        setRes();

        if (intArrayFetch == INT_HOMEMOONBACK_BODY && altBoss1Clear)
        {
            intArrayFetch = INT_HOMEMOONBACK_BODY2;
        }

        if (intArrayFetch == INT_PAINFRAME && boss2Clear)
        {
            intArrayFetch = INT_PAINFRAME_POST;
        }

        if (intArrayFetch == INT_THEDARK && boss3Clear)
        {
            intArrayFetch = INT_THEDARK_POST;
        }

        if (intArrayFetch == INT_TUNNELER)
        {
            AmbientSound("RPGTUNL",127);
        }

        else
        {
            AmbientSound("RPGMENUO",127);
        }

        int type = intArrayFetch;

        debugMessage = strParam(s:"OBJI ", i:type, s:"\n");

        //textBox(1,objInteractions[type+1],objInteractions[type+2]);

        int lines = objInteractions[type+3];
        int i = 0;
        while (i < lines)
        {
            clear(UI_TEXT);
            clear(UI_BOX);
            clear(UI_PORTBOX);
            clear(UI_PORT);
            // if (objInteractions[type+i+7] != EXP_NORMAL)
            // {
            //     textBox(1,INT_NPC,objInteractions[type+i+7]);
            // }
            // else
            // {
            textBox(1,objInteractions[type+1],objInteractions[type+2]);
            // }
            SetHudClipRect(0,0,0,0,207,TRUE);
            draw
            (
                anyDisks ? "UNSCII" : "GLTEX",
                strParam
                (
                    s:"\c[FamiGrey]",
                    s:objInteractions[type+0],
                    s:"\cl\n",
                    s:objInteractions[type+i+4]
                ),
                UI_TEXT,
                (objInteractions[type+1] == INT_OBJ ? 56.1 : 76.1),
                152.1
            );
            SetHudClipRect(0,0,0,0,0);

            debugMessage2 = strParam(s:"T_LN ", i:lines, s:"\nC_LN ", i:i, s:"\n");

            while (1)
            {
                if (inputUse)
                {i++; break;}
                Delay(1);
                debugMessageInput = StrParam(s:"WAIT");
            }
            AmbientSound("RPGSLOT",127);
            debugMessageInput = "";
            Delay(1);
        }
        debugMessage = "";
        debugMessage2 = "";
        textBox(0,0,0);
        drawHud();

        // SPECIAL CONDITIONS

        switch (intArrayFetch)
        {
            case INT_THEDARK:
            vHasControl = 0;
            ACS_NamedExecute("b_initBattle",0,bENEMY_DARK);
            break;

            case INT_MOONGUARD:
            vHasControl = 0;
            ACS_NamedExecute("b_initBattle",0,bENEMY_MOONGUARD);
            break;

            case INT_PAINFRAME:
            vHasControl = 0;
            ACS_NamedExecute("b_initBattle",0,bENEMY_PAINFRAME);
            break;

            case INT_GUTS:
            vHasControl = 0;
            ACS_NamedExecute("b_initBattle",0,bENEMY_GUTS);
            break;

            case INT_GLOW_TV:
            ACS_NamedExecute("tvEvent",0);
            break;

            case INT_HOMEMOONBACK_BODY:
            vHasControl = 0;
            ACS_NamedExecute("b_initBattle",0,bENEMY_ELPH2);
            break;

            case INT_MOON_BOOK_R:
            ACS_NamedExecute("sanity", 0);
            break;
        }
    }
}

script "roomChange" (int moveToRoom, int moveToXY)
{
    vTweenX = 0;
    vTweenY = 0;
    vHasControl = 0;
    ACS_NamedTerminate("sanity",0);
    clear(ZONE_BG);
    clear(ZONE_ROOM);
    clear(ZONE_SPRITE1);
    clear(ZONE_SPRITE2);
    clear(ZONE_SPRITE3);
    clear(ZONE_ELPH);
    ACS_NamedSuspend("sonataTimer",0);
    drawRoom(1);
    Delay(15);

    // progression
    for (int i = 0; i < crossingProgressionCount; i++)
    {
        if (vCurrentScreen == crossingProgressionSource[i] &&
            moveToRoom == crossingProgressionTarget[i] &&
            diskCheck(crossingProgressionDisk[i]))
        {
            moveToRoom = crossingProgressionOK[i];
            break;
        }
    }

    vCurrentScreen = moveToRoom;
    vRealPos = moveToXY;
    vWishPos = movetoXY;

    getElphXY();
    drawRoom(0);
    ACS_NamedExecute("sonataTimer",0);
    drawElph();

    Delay(5);
    vHasControl = 1;
}

script "areaSwitcher" (void)
{
    for (int i = 0; i < bgmEncounterDBsize/5; i++)
    {
        if (vCurrentScreen == bgmEncounterDB[i*5])
        {
			areaEncounters[0] = bgmEncounterDB[(i*5)+2];
			areaEncounters[1] = bgmEncounterDB[(i*5)+3];
            battleMusicSwitch = bgmEncounterDB[(i*5)+4];
            if (vLastMusic != bgmEncounterDB[(i*5)+1])
            {
                changeBGM(BGM_NONE,2,TRUE); Delay(10);
                changeBGM(bgmEncounterDB[(i*5)+1],1,TRUE);
            }
        }
    }
}

script "inGameMenu" (void)
{
    SetMusicVolume(0.0);
    PlaySound(0,"RPGMENUO",1);
    int menuSelected = 0;
    setRes();
    vHasControl = 0;
    draw("RPGMENU","A",UI_MENU,208.1,176.1);
    SetFont("UNSCII");
    HudMessage(s:"\c[FamiGrey]SONATA\n\n\n\n\n\n\n\c[FamiGrey]v0.",i:vRpgVersion,s:(GetCvar("diskDebug") ? "D" : "A");HUDMSG_PLAIN,UI_MENUINFO,CR_UNTRANSLATED,224.1,176.1,0);
    draw("UNSCII",strParam(s:"RETURN\n",s:(vHasTeleport > 0 ? strParam(s:"TPORT\c[FamiGrey]x",i:vHasTeleport) : "\c[FamiGrey]..."),s:"\n",s:(vHasBook ? "PRAY" : "\c[FamiGrey]..."),s:"\n",s:(altBoss2Clear ? (vPowerSpeed ? "\c[FamiBlue]SPEED\n" : "\c[FamiRed]POWER\n") : "\c[FamiGrey]...\n\cl"),s:(GetCvar("diskDebug") ? "DEBUG\n" : "???\n"),s:"RESET"),UI_MENUTEXT,224.1,184.1);

    while (1)
    {
        if (inputDown && menuSelected < 5) {menuSelected++; PlaySound(0,"RPGMENUS",1);}
        if (inputUp && menuSelected > 0) {menuSelected--; PlaySound(0,"RPGMENUS",1);}
        if (inputUse)
        {
            if (menuSelected == 0)
            {
                SetMusicVolume(1.0);
                vHasControl = 1;
                clear(UI_MENU);
                clear(UI_MENUINFO);
                clear(UI_MENUTEXT);
                clear(UI_MENUSELECTOR);
                Terminate;
            }

            if (menuSelected == 1)
            {
                if (vHasTeleport > 0)
                {
                    vHasTeleport--;
                    PlaySound(0,"RPGTELE",1);
                    changeBGM(BGM_NONE,2,FALSE);
                    vLastScreen = vCurrentScreen;
                    vCurrentScreen = ROOM_CROSSING;
                    ACS_NamedExecute("roomChange",0,vCurrentScreen,196);
                    clear(UI_MENU);
                    clear(UI_MENUINFO);
                    clear(UI_MENUTEXT);
                    clear(UI_MENUSELECTOR);
                    Delay(10);
                    SetMusicVolume(1.0);
                    ACS_NamedExecute("sonataTimer",0);
                    Terminate;
                }
                else
                {
                    PlaySound(0,"RPGMISS",1);
                }
            }

            if (menuSelected == 2)
            {
                if (vHasBook)
                {
                    switch (vCurrentScreen)
                    {
                        case ROOM_MYSTERY:
                            PlaySound(0,"RPGTELE",1);
                            changeBGM(BGM_NONE,2,FALSE);
                            vLastScreen = vCurrentScreen;
                            vCurrentScreen = ROOM_CHURCH;
                            ACS_NamedExecute("roomChange",0,vCurrentScreen,ENTER_CHURCH);
                            clear(UI_MENU);
                            clear(UI_MENUINFO);
                            clear(UI_MENUTEXT);
                            clear(UI_MENUSELECTOR);
                            Delay(10);
                            SetMusicVolume(1.0);
                            Terminate;
                        break;

                        case ROOM_CHURCH:
                            PlaySound(0,"RPGTELE",1);
                            changeBGM(BGM_NONE,2,FALSE);
                            vLastScreen = vCurrentScreen;
                            vCurrentScreen = ROOM_MYSTERY;
                            ACS_NamedExecute("roomChange",0,vCurrentScreen,ENTER_MYSTERY+40);
                            clear(UI_MENU);
                            clear(UI_MENUINFO);
                            clear(UI_MENUTEXT);
                            clear(UI_MENUSELECTOR);
                            Delay(10);
                            SetMusicVolume(1.0);
                            Terminate;
                        break;

                        case ROOM_MOON_HOUSE_END:
                            if (vRealPos == 149)
                            {
                                PlaySound(0,"RPGTELE",1);
                                changeBGM(BGM_NONE,2,FALSE);
                                clear(UI_MENU);
                                clear(UI_MENUINFO);
                                clear(UI_MENUTEXT);
                                clear(UI_MENUSELECTOR);
                                Delay(5);
                                SetMusicVolume(1.0);
                                ACS_NamedExecute("b_initBattle",0,bENEMY_MOON1);
                                Terminate;
                            }
                            else
                            {
                                PlaySound(0,"RPGMISS",1);
                            }
                        break;

                        default:
                            PlaySound(0,"RPGMISS",1);
                        break;
                    }
                    drawHud();
                }
                else
                {
                    PlaySound(0,"RPGMISS",1);
                }
            }

            if (menuSelected == 3)
            {
                if (altBoss2Clear)
                {
                    PlaySound(0,"RPGMENUS",1);
                    vPowerSpeed = !vPowerSpeed;
                    draw("UNSCII",strParam(s:"RETURN\n",s:(vHasTeleport > 0 ? strParam(s:"TPORT\c[FamiGrey]x",i:vHasTeleport) : "\c[FamiGrey]..."),s:"\n",s:(vHasBook ? "PRAY" : "\c[FamiGrey]..."),s:"\n",s:(altBoss2Clear ? (vPowerSpeed ? "\c[FamiBlue]SPEED\n" : "\c[FamiRed]POWER\n") : "\c[FamiGrey]...\n\cl"),s:(GetCvar("diskDebug") ? "DEBUG\n" : "???\n"),s:"RESET"),UI_MENUTEXT,224.1,184.1);
                    drawHud();
                }
                else
                {
                    PlaySound(0,"RPGMISS",1);
                }
            }

            if (menuSelected == 4)
            {
                if (GetCvar("diskDebug"))
                {
                    PlaySound(0,"RPGMENUO",1);
                    vOpenedDebug = 1;
                    ACS_NamedExecuteWait("inGameDebugMenu",0);
                }
                else
                {
                    PlaySound(0,"RPGMISS",1);
                }
            }

            if (menuSelected == 5)
            {
                AmbientSound("FDSON",127);
                changeBGM(BGM_NONE,2,FALSE);
                ACS_NamedTerminate("sonataTimeDsiplay",0);
                clearAll();
                ACS_NamedExecute("titleMenu",0);
                SetMusicVolume(1.0);
                Terminate;
            }
        }
        draw("UNSCII",">",UI_MENUSELECTOR,216.1,184.1+((menuSelected*8)<<16));
        Delay(1);
    }
}

function void debugReWriter (int battleType)
{
    draw("UNSCII",strParam
    (
        s:strParam(s:(debugger ? "ON" : "OFF")),s:"\n",
        i:vCurrentScreen,s:"\n",
        i:vPosX,s:"\n",
        i:vPosY,s:"\n",
        i:vHP,s:"\n",
        i:battleType,s:"\n",
        s:strParam(s:(battlesOn ? "ON" : "OFF"))
    ),
    UI_DEBUGMENUVALUES,264.1,160.1);
}

function void debugRoomSwitch (void)
{
    ACS_NamedTerminate("sanity",0);
    clear(ZONE_SPRITE1);
    clear(ZONE_SPRITE2);
    clear(ZONE_SPRITE3);
    drawRoom(0);
    drawElph();
}

script "inGameDebugMenu" (void)
{
    int menuSelected = 0;
    int battleType = 0;
    draw("RPGDMENU","A",UI_DEBUGMENU,208.1,152.1);
    draw("UNSCII","INFO\nROOM\nPOSX\nPOSY\nMIND\nTEST\nBATT\nGIVE\nBACK",UI_DEBUGMENUTEXT,224.1,160.1);
    debugReWriter(battleType);
    while (1)
    {
        if (inputUp && menuSelected > 0)
        {
            menuSelected--;
            PlaySound(0,"RPGMENUS",1);
        }
        if (inputDown && menuSelected < 8)
        {
            menuSelected++;
            PlaySound(0,"RPGMENUS",1);
        }
        draw("UNSCII",">",UI_DEBUGMENUSELECTOR,216.1,160.1+((menuSelected*8)<<16));

        if (inputLeft)
        {
            if (menuSelected == 0)
            {
                ACS_NamedExecute("rpg_debugger",0);
                debugger = !debugger;
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 1)
            {
                vCurrentScreen--;
                if (vCurrentScreen < 0) {vCurrentScreen = 143;}
                debugRoomSwitch();
                Delay(1);
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 2)
            {
                vPosX--;
                if (vPosX < 0) {vPosX = 19;}
                drawElph();
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 3)
            {
                vPosY--;
                if (vPosY < 0) {vPosY = 13;}
                drawElph();
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 4)
            {
                vHP -= 5;
                if (vHP < 1) {vHP = 1;}
                drawHud();
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 5)
            {
               battleType--;
               if (battleType < 0) {battleType = 99;}
               debugReWriter(battleType);
               PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 6)
            {
                battlesOn = !battlesOn;
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
        }

        if (inputRight)
        {
            if (menuSelected == 0)
            {
                ACS_NamedExecute("rpg_debugger",0);
                debugger = !debugger;
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 1)
            {
                vCurrentScreen++;
                if (vCurrentScreen > 143) {vCurrentScreen = 0;}
                debugRoomSwitch();
                Delay(1);
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 2)
            {
                vPosX++;
                if (vPosX > 19) {vPosX = 0;}
                drawElph();
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 3)
            {
                vPosY++;
                if (vPosY > 13) {vPosY = 0;}
                drawElph();
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 4)
            {
                vHP += 5;
                if (vHP > 40) {vHP = 40;}
                drawHud();
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 5)
            {
               battleType++;
               if (battleType > 99) {battleType = 0;}
               debugReWriter(battleType);
               PlaySound(0,"RPGMENUS",1);
            }
            if (menuSelected == 6)
            {
                battlesOn = !battlesOn;
                debugReWriter(battleType);
                PlaySound(0,"RPGMENUS",1);
            }
        }

        if (inputUse)
        {
            if (menuSelected == 5)
            {
                SetMusicVolume(1.0);
                ACS_NamedTerminate("inGameMenu",0);
                clear(UI_MENU);
                clear(UI_MENUINFO);
                clear(UI_MENUTEXT);
                clear(UI_MENUSELECTOR);
                Clear(UI_DEBUGMENU);
                Clear(UI_DEBUGMENUTEXT);
                Clear(UI_DEBUGMENUSELECTOR);
                Clear(UI_DEBUGMENUVALUES);
                vHasControl = 1;
                ACS_NamedExecute("b_initBattle",0,battleType*12);
                Terminate;
            }
            if (menuSelected == 7)
            {
                PlaySound(0,"RPGMENUS",1);
                debugGive();
                drawHud();
            }

            if (menuSelected ==8)
            {
                PlaySound(0,"RPGMENUB",1);
                Clear(UI_DEBUGMENU);
                Clear(UI_DEBUGMENUTEXT);
                Clear(UI_DEBUGMENUSELECTOR);
                Clear(UI_DEBUGMENUVALUES);
                Terminate;
            }
        }
        Delay(1);
    }
}

script "HPtracker" (void)
{
    While (vHP > 0)
    {
        Delay(5);
    }
    if (vCurrentScreen == ROOM_HOMEMOON)
    {
        ACS_NamedTerminate("sanity",0);
        ACS_NamedExecute("gameOver",0,GO_MOONROOM);
        Terminate;
    }
}

script "gameOver" (int type)
{
    drawTime = 0;
    ACS_NamedTerminate("sonataTimer",0);
    vHP = 0;
    changeBGM(BGM_NONE,2,FALSE);
    clearAll();
    debugMessage="";
    debugMessage2="";
    debugMessage3="";
    vHasControl = 0;
    vRealPos = 0;
    vWishPos = 0;
    vPosX = 0;
    vPosY = 0;

    if (type == GO_MOONROOM)
    {
        Delay(20);
        debugmessage2 = "SCREEN_GAMEOVER\n";
        draw("RPGOVER","A",ZONE_BG,160.0,192.2);
        draw("UNSCII","GAME OVER",ZONE_ROOM,160.0,208.2);
        changeBGM(BGM_MOONISH,1,FALSE);
        Delay(15);
        debugmessage2 = "";
        clear(ZONE_BG);
        clear(ZONE_ROOM);
        changeBGM(BGM_NONE,2,FALSE);
        Delay(5);
        debugmessage2 = "SCREEN_ILLDOITAGAIN\n";
        draw("GO_ANGEL","A",ZONE_BG,160.0,208.2);
        draw("UNSCII","******* ********",ZONE_ROOM,160.0,224.2);
        changeBGM(BGM_ANGEL,2,FALSE);
        Delay(65);
        changeBGM(BGM_NONE,2,FALSE);
        clear(ZONE_BG);
        clear(ZONE_ROOM);
        Delay(10);
        ACS_NamedExecute("titleMenu",0);
    }

    if (type == GO_NORMAL || type == GO_GUTS)
    {
        if (type == GO_GUTS)
        {
            for (int i = 0; i < 14; i++)
            {
                int eyeCount = i+1;
                if (eyeCount > 4) {eyeCount = 5+(i%2);}
                draw(strParam(s:"RPGEYE",i:eyeCount),"A",UI_HUDFACE,0.1,0.1);
                Delay((i < 2 ? 4 : 2));
            }
            clear(UI_HUDFACE);
        }
        Delay(20);
        debugmessage2 = "SCREEN_GAMEOVER\n";
        draw("RPGOVER","A",ZONE_BG,160.0,192.2);
        draw("UNSCII","GAME OVER",ZONE_ROOM,160.0,208.2);
        changeBGM(BGM_MOONISH,1,FALSE);
        while (!inputUse)
        {
            Delay(1);
            debugMessageInput = StrParam(s:"WAIT");
        }
        debugMessageInput = "";
        changeBGM(BGM_NONE,2,FALSE);
        clear(ZONE_BG);
        clear(ZONE_ROOM);
        Delay(10);
        ACS_NamedExecute("titleMenu",0);
    }
}

script "sanity" (void)
{
    while (1)
    {
        for (int i = 0; i < 15; i++)
        {
            Delay(2);
            debugmessage2 = strParam(s:"TIME ", i:vSanityTimer, s:".", i:i, s:"\n", i:(vSanityTimer/5), s:" DMG\n");
        }
        if (vHasControl)
        {
            vSanityTimer++;
            if (vSanityTimer > 2)
            {
                vHP -= vSanityTimer/3;
            }
            drawHud();
        }
        Delay(1);
        if (vHP < 0)
        {
            ACS_NamedExecute("gameOver",0,GO_MOONROOM);
            Terminate;
        }
    }
}

// BATTLE ////////////////////////

function void b_ClearFX (void)
{
	for (int i = 0; i < 12; i++)
	{
		clear(BATTLE_FX+i);
	}
}

function void b_ClearSquares (void)
{
	for (int i = 0; i < 10; i++)
	{
		clear(BATTLE_SQUARE+i);
	}
}

function void b_ClearIcons (void)
{
	for (int i = 0; i < 8; i++)
	{
		clear(BATTLE_ICONS+i);
	}
}

function void b_ClearATBmeter (void)
{
	for (int i = 0; i < 100; i++)
	{
		clear(BATTLE_ATBMETER-i);
	}
}

function void b_ClearSlot (void)
{
	for (int i = 0; i < 4; i++)
	{
		clear(BATTLE_SLOT+i);
	}
}

function void b_ClearAll (void)
{
	b_ClearFX();
	b_ClearSquares();
	b_ClearIcons();
	b_ClearATBmeter();
	clear(BATTLE_DMGNUM);
	clear(BATTLE_ELPH);
	clear(BATTLE_INFO1);
	clear(BATTLE_INFO2);
	clear(BATTLE_ENEMY);
    clear(BATTLE_ENEMY-1);
    clear(BATTLE_ENEMY-2);
	clear(BATTLE_GRID);
	clear(BATTLE_BG);
}

function void b_killScriptsSounds (void)
{
    ACS_NamedTerminate("b_potionHeal",0);
    ACS_NamedTerminate("b_bombLaunch",0);
    ACS_NamedTerminate("b_bombExplosions",0);
    ACS_NamedTerminate("b_drawEnemy",0);
    ACS_NamedTerminate("b_moveHandler",0);
    ACS_NamedTerminate("b_battleMenu",0);
    ACS_NamedTerminate("b_ATB",0);
    ACS_NamedTerminate("b_attackSquare",0);
    ACS_NamedTerminate("b_winExplosions",0);
    ACS_NamedTerminate(strParam(s:"b_attackPatterns",i:bEnemyType),0);
    StopSound(0,1);
    StopSound(0,2);
    StopSound(0,3);
    StopSound(0,4);
    StopSound(0,5);
}

script "b_initBattle" (int eType)
{
    if (eType == bENEMY_ATLAS || eType == bENEMY_ELPH2 || eType == bENEMY_FLY || eType == bENEMY_MOONGUARD || eType == bENEMY_GUTS || eType == bENEMY_PAINFRAME || eType == bENEMY_DARK || eType == bENEMY_MOON1 || eType == bENEMY_MOON2 || eType == bENEMY_SYSTEM)
    {
        bEnemyBoss = 1;
    }
    else {bEnemyBoss = 0;}

    drawTime = 0;
    bSafetyCheck = 1;
    vHasControl = 0;
    if (battleMusicSwitch)
    {
        SetMusicVolume(0.0);
        changeBGM(BGM_NONE,2,FALSE);
        if (eType != bENEMY_MOON1 && eType != bENEMY_MOON2 && eType != bENEMY_SYSTEM) {AmbientSound("RPGENCNT",127);}
    }

	for (int i = 1; i <= 8; i++)
	{
		str texture = strParam(s:"RPGBS",i:i);
		for (int j = 0; j < 320; j++)
		{
			draw(texture,"A",UI_BATTLESTART+j,
			0.1 + (((j%20)*16)<<16),
			0.1 + (((j/20)*16)<<16));
		}
		Delay(2);
	}
	Delay(23);

    if (battleMusicSwitch)
    {
        changeBGM(enemyDB[eType+7],0,FALSE);
        SetMusicVolume(1.0);
    }
    bEnemyHP = enemyDB[eType+2];
    bEnemyName = enemyDB[eType];
    bEnemyType = eType;
    bEnemyAttacking = 0;

    b_ClearAll();
    clear(UI_MENU);
    clear(UI_MENUINFO);
    clear(UI_MENUTEXT);
    clear(UI_BOX);
    clear(UI_MENUSELECTOR);
    clear(UI_PORTBOX);
    clear(UI_PORT);
    clear(UI_TEXT);
    clear(UI_MENUSELECTOR);
    clear(UI_HUDBAR);
    clear(UI_HUDFACE);
    clear(UI_HUDKEY1);
    clear(UI_HUDKEY2);
    clear(UI_HUDKEY3);
    clear(UI_HUDSKATE);
    clear(UI_HUDBAND);
    clear(UI_HUDBOOK);
    clear(UI_HUDROOMNAME);
    clear(ZONE_ELPH);
    clear(ZONE_ROOM);
    clear(ZONE_SPRITE1);
    clear(ZONE_SPRITE2);
    clear(ZONE_SPRITE3);
    clear(ZONE_BG);

    bElphPos = 4;

    ACS_NamedExecute("b_drawEnemy",0);
    b_drawHUD();
    b_ATBreset();
    draw("RPGBTILE","A",BATTLE_GRID, BATTLE_GRID_X, BATTLE_GRID_Y);
    draw(enemyDB[eType+8],"A",BATTLE_BG,160.0,128.0);

	for (i = 8; i <= 15; i++)
	{
		texture = strParam(s:"RPGBS",i:i);
		for (j = 0; j < 320; j++)
		{
			draw(texture,"A",UI_BATTLESTART+j,
			0.1 + (((j%20)*16)<<16),
			0.1 + (((j/20)*16)<<16));
		}
		Delay(2);
	}
	for (j = 0; j < 320; j++)
	{
		clear(UI_BATTLESTART+j);
	}

	bHasControl = 1;
    ACS_NamedExecute("b_moveHandler",0);
	Delay(90);
    ACS_NamedExecute(strParam(s:"b_attackPatterns",i:eType),0);
}

script "b_drawEnemy" (void)
{
    bXSine = 0;
    bYSine = 0;
    bXOffset = 0;
    bYOffset = 0;

    int bXSineLH = 0;
    int bYSineLH = 0;
    int bXOffsetLH = 0;
    int bYOffsetLH = 0;
    int bXSineRH = 0;
    int bYSineRH = 0;
    int bXOffsetRH = 0;
    int bYOffsetRH = 0;

    bYAmp = enemyDB[bEnemyType+3];
    bYFreq = enemyDB[bEnemyType+4];
    bXAmp = enemyDB[bEnemyType+5];
    bXFreq = enemyDB[bEnemyType+6];

    while (1)
    {
        bXOffset = (FixedMul(sin(bXSine), bXAmp << 16)) >> 16;
        bXSine = (bXSine + bXFreq) % 65535;
        bYOffset = (FixedMul(sin(bYSine), bYAmp << 16)) >> 16;
        bYSine = (bYSine + bYFreq) % 65535;
        if (Timer()%7 < 3 && bEnemyHurt == 1 && bEnemyType != bENEMY_ATLAS)
        {
            clear(BATTLE_ENEMY);
            clear(BATTLE_ENEMY-1);
            clear(BATTLE_ENEMY-2);
        }
        else
        {
            // draw(enemyDB[bEnemyType+1], "A", BATTLE_ENEMY, BATTLE_GRID_X + (bXOffset << 16), (BATTLE_GRID_Y-112.0) + (bYOffset << 16));
			setRes();
			setFont((strParam(s:enemyDB[bEnemyType+1],s:(bEnemyHurt && Timer()%2 == 0 ? "X" : ""))));
			HudMessage
			(
			s:"A";
			HUDMSG_PLAIN,
			BATTLE_ENEMY,
			CR_UNTRANSLATED,
			BATTLE_GRID_X + (bXOffset << 16),
			(BATTLE_GRID_Y-112.0) + (bYOffset << 16),
			0
			);

            if (bEnemyType == bENEMY_MOON1)
            {
                bXOffsetLH = (FixedMul(sin(bXSineLH), 4 << 16)) >> 16;
                bXSineLH = (bXSineLH + Floor(bXFreq*0.9)) % 65535;
                bYOffsetLH = (FixedMul(sin(bYSineLH), 4 << 16)) >> 16;
                bYSineLH = (bYSineLH + Floor(bYFreq*0.9)) % 65535;

                bXOffsetRH = (FixedMul(sin(bXSineRH), 4 << 16)) >> 16;
                bXSineRH = (bXSineRH + Floor(bXFreq*0.85)) % 65535;
                bYOffsetRH = (FixedMul(sin(bYSineRH), 4 << 16)) >> 16;
                bYSineRH = (bYSineRH + Floor(bYFreq*0.85)) % 65535;

                setRes();
                setFont("RPGNMEK1");
                HudMessage
                (
                s:"A";
                HUDMSG_PLAIN,
                BATTLE_ENEMY-1,
                CR_UNTRANSLATED,
                (BATTLE_GRID_X-96.0) + (bXOffsetLH << 16),
                (BATTLE_GRID_Y-16.0) + (bYOffsetLH << 16),
                0
                );

                setRes();
                setFont("RPGNMEK2");
                HudMessage
                (
                s:"A";
                HUDMSG_PLAIN,
                BATTLE_ENEMY-2,
                CR_UNTRANSLATED,
                (BATTLE_GRID_X+96.0) + (bXOffsetRH << 16),
                (BATTLE_GRID_Y-16.0) + (bYOffsetRH << 16),
                0
                );
            }
        }
        Delay(1);
    }
}

function void b_drawHUD (void)
{
	if (bSafetyCheck)
	{
        str battleEnemyInfo = strparam(s:(bEnemyAttacking ? strParam(s:"\c[FamiRed]",s:bEnemyName) : bEnemyName),s:"\n",i:bEnemyHP);
        draw("UNSCII",battleEnemyInfo,BATTLE_INFO2,162.4,158.0);
        draw("RPGBUI","A",BATTLE_ATBMETER,BATTLE_GRID_X,BATTLE_GRID_Y+32.0);
        drawElphHPmeter();
	}
}

script "b_battleMenu" (void)
{
    bATBactive = 0;
    PlaySound(0,"RPGATBF",4);
    draw("RPGBICOE","A",BATTLE_ICONS,BATTLE_GRID_X-16.0,BATTLE_GRID_Y-16.0);
    draw("RPGBICOD","A",BATTLE_ICONS+1,BATTLE_GRID_X+16.0,BATTLE_GRID_Y-16.0);
    if (!bEnemyBoss) {draw("RPGBICOC","A",BATTLE_ICONS+2,BATTLE_GRID_X,BATTLE_GRID_Y+16.0);}
    draw("RPGBICOB","A",BATTLE_ICONS+3,BATTLE_GRID_X,BATTLE_GRID_Y);
    if (vHasBomb) {draw("RPGBOMW","A",BATTLE_ICONS+4,BATTLE_GRID_X-16.0,BATTLE_GRID_Y+16.0);}
    if (vHasPotion) {draw("RPGPOTW","A",BATTLE_ICONS+5,BATTLE_GRID_X+16.0,BATTLE_GRID_Y+16.0);}
    Delay(2);
    draw(strParam(s:"RPGBBOW",i:vBowBoost),"A",BATTLE_ICONS,BATTLE_GRID_X-16.0,BATTLE_GRID_Y-16.0);
    draw(strParam(s:"RPGBMEL",i:vMeleeBoost),"A",BATTLE_ICONS+1,BATTLE_GRID_X+16.0,BATTLE_GRID_Y-16.0);
    if (!bEnemyBoss) {draw("RPGBICO3","A",BATTLE_ICONS+2,BATTLE_GRID_X,BATTLE_GRID_Y+16.0);}
    draw("RPGBICO8","A",BATTLE_ICONS+3,BATTLE_GRID_X,BATTLE_GRID_Y);
    if (vHasBomb) {draw("RPGBOM","A",BATTLE_ICONS+4,BATTLE_GRID_X-16.0,BATTLE_GRID_Y+16.0);}
    if (vHasPotion) {draw("RPGPOT","A",BATTLE_ICONS+5,BATTLE_GRID_X+16.0,BATTLE_GRID_Y+16.0);}
    while (!inputUse && bSafetyCheck)
    {
        Delay(1);
    }
    switch (bElphPos)
    {
        case 0:
            if (bSafetyCheck)
            {
                ACS_NamedExecute("b_elphAttack",0,bPATK_BOW);
                PlaySound(0,"RPGBSEL1",2);
                draw("RPGBTILG","A",BATTLE_GRID, BATTLE_GRID_X, BATTLE_GRID_Y);
                Delay(1);
                draw("RPGBTILE","A",BATTLE_GRID, BATTLE_GRID_X, BATTLE_GRID_Y);
            }
            break;

        case 2:
            if (bSafetyCheck)
            {
                ACS_NamedExecute("b_elphAttack",0,bPATK_MELEE);
                PlaySound(0,"RPGBSEL1",2);
                draw("RPGBTILG","A",BATTLE_GRID, BATTLE_GRID_X, BATTLE_GRID_Y);
                Delay(1);
                draw("RPGBTILE","A",BATTLE_GRID, BATTLE_GRID_X, BATTLE_GRID_Y);
            }
            break;

		case 4:
            if (bSafetyCheck)
            {
                ACS_NamedExecute("b_elphHeal",0);
                PlaySound(0,"RPGBSEL1",2);
                draw("RPGBTILG","A",BATTLE_GRID, BATTLE_GRID_X, BATTLE_GRID_Y);
                Delay(1);
                draw("RPGBTILE","A",BATTLE_GRID, BATTLE_GRID_X, BATTLE_GRID_Y);
            }
            break;

        case 6:
            if (bSafetyCheck)
            {
                if (vHasBomb)
                {
                    PlaySound(0,"RPGBSEL1",2);
                    draw("RPGBTILG","A",BATTLE_GRID, BATTLE_GRID_X, BATTLE_GRID_Y);
                    Delay(1);
                    draw("RPGBTILE","A",BATTLE_GRID, BATTLE_GRID_X, BATTLE_GRID_Y);
                    ACS_NamedExecute("b_bombLaunch",0);
                    vHasBomb = 0;
                }
                else
                {
                    ACS_NamedExecute("b_battleMenuMiss",0);
                }
            }
            b_ATBreset();
            break;

        case 7:
            if (bSafetyCheck && !bEnemyBoss)
            {
                PlaySound(0,"RPGBSEL1",2);
                draw("RPGBTILG","A",BATTLE_GRID, BATTLE_GRID_X, BATTLE_GRID_Y);
                Delay(1);
                draw("RPGBTILE","A",BATTLE_GRID, BATTLE_GRID_X, BATTLE_GRID_Y);
                ACS_NamedExecute("b_runSlot",0);
            }
            else
            {
                ACS_NamedExecute("b_battleMenuMiss",0);
                b_ATBreset();
            }
            break;

        case 8:
            if (bSafetyCheck)
            {
                if (vHasPotion)
                {
                    PlaySound(0,"RPGBSEL1",2);
                    draw("RPGBTILG","A",BATTLE_GRID, BATTLE_GRID_X, BATTLE_GRID_Y);
                    Delay(1);
                    draw("RPGBTILE","A",BATTLE_GRID, BATTLE_GRID_X, BATTLE_GRID_Y);
                    vHasPotion = 0;
                    ACS_NamedExecute("b_potionHeal",0);
                }
                else
                {
                    ACS_NamedExecute("b_battleMenuMiss",0);
                }
            }
            b_ATBreset();
            break;

        default:
            if (bSafetyCheck)
            {
                ACS_NamedExecute("b_battleMenuMiss",0);
            }
            b_ATBreset();
            break;
    }
    b_clearIcons();
}

script "b_potionHeal" (void)
{
    if (vHP > 0 && bSafetyCheck)
    {
        vHP += 40;
        if (vHP > 40) {vHP = 40;}
        PlaySound(0,"RPGPOT",2);
        ACS_NamedTerminate("b_dmgNum",0);
    }
    delay(1);
    ACS_NamedExecute("b_dmgNum",0,40,1,bElphPos+100);
    b_drawHUD();
}

script "b_bombLaunch" (void)
{
    int bombDMG = (getRNG()%10)+65;
    for (int i = 1; i < 8; i++)
    {
        ACS_NamedExecuteAlways("b_bombExplosions",0,i);
        Delay(3);
    }
	if (bSafetyCheck)
	{
		ACS_NamedTerminate("b_dmgNum",0);
		delay(1);
        ACS_NamedExecute("b_dmgNum",0,bombDMG);
		bEnemyHP -= bombDMG;
		if (bEnemyHP < 0) {bEnemyHP = 0;}
		b_drawHUD();
		b_ATBreset();
	}

	if (bEnemyHP > 0 && bSafetyCheck)
	{
        ACS_NamedExecute("b_hurtEnemyFeedback",0,bombDMG);
	}
	else
	{
		ACS_NamedExecute("b_win",0);
	}
}

script "b_elphHeal" (void)
{
    int attackProgress = 0;
    int attackStrength = 1;
    int attackBonusTimer = 0;
	int attackBonus = 3;
    draw("RPGBICOB","A",BATTLE_ICONS,BATTLE_GRID_X-16.0,BATTLE_GRID_Y-16.0);
    draw("RPGBICOB","A",BATTLE_ICONS+1,BATTLE_GRID_X,BATTLE_GRID_Y-16.0);
    draw("RPGBICOB","A",BATTLE_ICONS+2,BATTLE_GRID_X+16.0,BATTLE_GRID_Y-16.0);
    draw("RPGBICOB","A",BATTLE_ICONS+3,BATTLE_GRID_X-16.0,BATTLE_GRID_Y);
    draw("RPGBICOB","A",BATTLE_ICONS+4,BATTLE_GRID_X+16.0,BATTLE_GRID_Y);
    draw("RPGBICOB","A",BATTLE_ICONS+5,BATTLE_GRID_X-16.0,BATTLE_GRID_Y+16.0);
    draw("RPGBICOB","A",BATTLE_ICONS+6,BATTLE_GRID_X,BATTLE_GRID_Y+16.0);
    draw("RPGBICOB","A",BATTLE_ICONS+7,BATTLE_GRID_X+16.0,BATTLE_GRID_Y+16.0);
    Delay(2);
	while (attackProgress != 255 && bSafetyCheck)
	{
		draw(strParam(s:(attackProgress & 1 ? "RPGBICOA" : "RPGBICO9")),"A",BATTLE_ICONS,BATTLE_GRID_X-16.0,BATTLE_GRID_Y-16.0);
		draw(strParam(s:(attackProgress & 2 ? "RPGBICOA" : "RPGBICO9")),"A",BATTLE_ICONS+1,BATTLE_GRID_X,BATTLE_GRID_Y-16.0);
		draw(strParam(s:(attackProgress & 4 ? "RPGBICOA" : "RPGBICO9")),"A",BATTLE_ICONS+2,BATTLE_GRID_X+16.0,BATTLE_GRID_Y-16.0);
		draw(strParam(s:(attackProgress & 8 ? "RPGBICOA" : "RPGBICO9")),"A",BATTLE_ICONS+3,BATTLE_GRID_X-16.0,BATTLE_GRID_Y);
		draw(strParam(s:(attackProgress & 16 ? "RPGBICOA" : "RPGBICO9")),"A",BATTLE_ICONS+4,BATTLE_GRID_X+16.0,BATTLE_GRID_Y);
		draw(strParam(s:(attackProgress & 32 ? "RPGBICOA" : "RPGBICO9")),"A",BATTLE_ICONS+5,BATTLE_GRID_X-16.0,BATTLE_GRID_Y+16.0);
		draw(strParam(s:(attackProgress & 64 ? "RPGBICOA" : "RPGBICO9")),"A",BATTLE_ICONS+6,BATTLE_GRID_X,BATTLE_GRID_Y+16.0);
		draw(strParam(s:(attackProgress & 128 ? "RPGBICOA" : "RPGBICO9")),"A",BATTLE_ICONS+7,BATTLE_GRID_X+16.0,BATTLE_GRID_Y+16.0);

		if (bElphPos == 0 && !(attackProgress & 1)) {attackProgress |= 1; attackStrength += attackBonus; PlaySound(0,"RPGBSEL2",2);}
		if (bElphPos == 1 && !(attackProgress & 2)) {attackProgress |= 2; attackStrength += attackBonus; PlaySound(0,"RPGBSEL2",2);}
		if (bElphPos == 2 && !(attackProgress & 4)) {attackProgress |= 4; attackStrength += attackBonus; PlaySound(0,"RPGBSEL2",2);}
		if (bElphPos == 3 && !(attackProgress & 8)) {attackProgress |= 8; attackStrength += attackBonus; PlaySound(0,"RPGBSEL2",2);}
		if (bElphPos == 5 && !(attackProgress & 16)) {attackProgress |= 16; attackStrength += attackBonus; PlaySound(0,"RPGBSEL2",2);}
		if (bElphPos == 6 && !(attackProgress & 32)) {attackProgress |= 32; attackStrength += attackBonus; PlaySound(0,"RPGBSEL2",2);}
		if (bElphPos == 7 && !(attackProgress & 64)) {attackProgress |= 64; attackStrength += attackBonus; PlaySound(0,"RPGBSEL2",2);}
		if (bElphPos == 8 && !(attackProgress & 128)) {attackProgress |= 128; attackStrength += attackBonus; PlaySound(0,"RPGBSEL2",2);}

		attackBonusTimer = (attackBonusTimer+1)%2;
		if (attackBonusTimer == 1 && attackStrength > 1) {attackStrength--;}
        if (debugger) {debugMessage3 = strParam(s:"HEAL ",i: attackStrength,s:" ",i:attackProgress);}
		Delay(1);
	}
	b_clearIcons();
	b_ATBreset();
    if (vHP > 0 && bSafetyCheck)
    {
        vHP += attackStrength;
        if (vHP > 40) {vHP = 40;}
        PlaySound(0,"RPGHEAL",2);
        ACS_NamedTerminate("b_dmgNum",0);
        draw("RPGBTILG","A",BATTLE_GRID, BATTLE_GRID_X, BATTLE_GRID_Y);
    }
	delay(1);
	ACS_NamedExecute("b_dmgNum",0,attackStrength,1,bElphPos+100);
	b_drawHUD();
    Delay(1);
    if (vHP > 0 && bSafetyCheck) {draw("RPGBTILE","A",BATTLE_GRID, BATTLE_GRID_X, BATTLE_GRID_Y);}
}

script "b_elphAttack" (int attackType)
{
    int attackProgress = 0;
    int attackStrength = 1;
    int attackBonusTimer = 0;
    bool attackPattern = getRNG()%2;
	int attackBonus = 0;
	switch (attackType)
	{
		case bPATK_BOW:
		attackBonus = (altBoss2Clear && vPowerSpeed == 0 ? 10 : 8);
		break;

		case bPATK_MELEE:
		attackBonus = (altBoss2Clear && vPowerSpeed == 0 ? 8 : 6);
		break;
	}

    if (attackType == bPATK_BOW)
    {
        attackBonus = attackBonus + (vBowBoost);
        if (attackPattern)
        {
            draw("RPGBICOE","A",BATTLE_ICONS,BATTLE_GRID_X,BATTLE_GRID_Y-16.0);
            draw("RPGBICOE","A",BATTLE_ICONS+1,BATTLE_GRID_X-16.0,BATTLE_GRID_Y);
            draw("RPGBICOE","A",BATTLE_ICONS+2,BATTLE_GRID_X+16.0,BATTLE_GRID_Y);
        }
        else
        {
            draw("RPGBICOE","A",BATTLE_ICONS,BATTLE_GRID_X,BATTLE_GRID_Y);
            draw("RPGBICOE","A",BATTLE_ICONS+1,BATTLE_GRID_X-16.0,BATTLE_GRID_Y+16.0);
            draw("RPGBICOE","A",BATTLE_ICONS+2,BATTLE_GRID_X+16.0,BATTLE_GRID_Y+16.0);
        }
    }
    else if (attackType == bPATK_MELEE)
    {
        attackBonus = attackBonus + (vMeleeBoost);
        if (attackPattern)
        {
            draw("RPGBICOD","A",BATTLE_ICONS,BATTLE_GRID_X-16.0,BATTLE_GRID_Y);
            draw("RPGBICOD","A",BATTLE_ICONS+1,BATTLE_GRID_X,BATTLE_GRID_Y);
            draw("RPGBICOD","A",BATTLE_ICONS+2,BATTLE_GRID_X+16.0,BATTLE_GRID_Y);
        }
        else
        {
            draw("RPGBICOD","A",BATTLE_ICONS,BATTLE_GRID_X,BATTLE_GRID_Y-16.0);
            draw("RPGBICOD","A",BATTLE_ICONS+1,BATTLE_GRID_X,BATTLE_GRID_Y);
            draw("RPGBICOD","A",BATTLE_ICONS+2,BATTLE_GRID_X,BATTLE_GRID_Y+16.0);
        }
    }
    Delay(2);

    if (attackType == bPATK_BOW)
    {
        while (attackProgress != 7 && bSafetyCheck)
        {
            if (attackPattern)
            {
                draw(strParam(s:(attackProgress & 1 ? "RPGBICO7" : "RPGBICO6")),"A",BATTLE_ICONS,BATTLE_GRID_X,BATTLE_GRID_Y-16.0);
                draw(strParam(s:(attackProgress & 2 ? "RPGBICO7" : "RPGBICO6")),"A",BATTLE_ICONS+1,BATTLE_GRID_X-16.0,BATTLE_GRID_Y);
                draw(strParam(s:(attackProgress & 4 ? "RPGBICO7" : "RPGBICO6")),"A",BATTLE_ICONS+2,BATTLE_GRID_X+16.0,BATTLE_GRID_Y);

                if (bElphPos == 1 && !(attackProgress & 1)) {attackProgress |= 1; attackStrength += attackBonus; PlaySound(0,"RPGBSEL2",2);}
                if (bElphPos == 3 && !(attackProgress & 2)) {attackProgress |= 2; attackStrength += attackBonus; PlaySound(0,"RPGBSEL2",2);}
                if (bElphPos == 5 && !(attackProgress & 4)) {attackProgress |= 4; attackStrength += attackBonus; PlaySound(0,"RPGBSEL2",2);}
            }

            else
            {
                draw(strParam(s:(attackProgress & 1 ? "RPGBICO7" : "RPGBICO6")),"A",BATTLE_ICONS,BATTLE_GRID_X,BATTLE_GRID_Y);
                draw(strParam(s:(attackProgress & 2 ? "RPGBICO7" : "RPGBICO6")),"A",BATTLE_ICONS+1,BATTLE_GRID_X-16.0,BATTLE_GRID_Y+16.0);
                draw(strParam(s:(attackProgress & 4 ? "RPGBICO7" : "RPGBICO6")),"A",BATTLE_ICONS+2,BATTLE_GRID_X+16.0,BATTLE_GRID_Y+16.0);

                if (bElphPos == 4 && !(attackProgress & 1)) {attackProgress |= 1; attackStrength += attackBonus; PlaySound(0,"RPGBSEL2",2);}
                if (bElphPos == 6 && !(attackProgress & 2)) {attackProgress |= 2; attackStrength += attackBonus; PlaySound(0,"RPGBSEL2",2);}
                if (bElphPos == 8 && !(attackProgress & 4)) {attackProgress |= 4; attackStrength += attackBonus; PlaySound(0,"RPGBSEL2",2);}
            }

            attackBonusTimer = (attackBonusTimer+1)%2;
            if (attackBonusTimer == 1 && attackStrength > 1) {attackStrength--;}
            if (debugger) {debugMessage3 = strParam(s:"ATKB ",i: attackStrength,s:" ",i:attackProgress);}
            Delay(1);
        }
    }

    else if (attackType == bPATK_MELEE)
    {
        while (attackProgress != 7 && bSafetyCheck)
        {
            if (attackPattern)
            {
                draw(strParam(s:(attackProgress & 1 ? "RPGBICO5" : "RPGBICO4")),"A",BATTLE_ICONS,BATTLE_GRID_X-16.0,BATTLE_GRID_Y);
                draw(strParam(s:(attackProgress & 2 ? "RPGBICO5" : "RPGBICO4")),"A",BATTLE_ICONS+1,BATTLE_GRID_X,BATTLE_GRID_Y);
                draw(strParam(s:(attackProgress & 4 ? "RPGBICO5" : "RPGBICO4")),"A",BATTLE_ICONS+2,BATTLE_GRID_X+16.0,BATTLE_GRID_Y);

                if (bElphPos == 3 && !(attackProgress & 1)) {attackProgress |= 1; attackStrength += attackBonus; PlaySound(0,"RPGBSEL2",2);}
                if (bElphPos == 4 && !(attackProgress & 2)) {attackProgress |= 2; attackStrength += attackBonus; PlaySound(0,"RPGBSEL2",2);}
                if (bElphPos == 5 && !(attackProgress & 4)) {attackProgress |= 4; attackStrength += attackBonus; PlaySound(0,"RPGBSEL2",2);}
            }

            else
            {
                draw(strParam(s:(attackProgress & 1 ? "RPGBICO5" : "RPGBICO4")),"A",BATTLE_ICONS,BATTLE_GRID_X,BATTLE_GRID_Y-16.0);
                draw(strParam(s:(attackProgress & 2 ? "RPGBICO5" : "RPGBICO4")),"A",BATTLE_ICONS+1,BATTLE_GRID_X,BATTLE_GRID_Y);
                draw(strParam(s:(attackProgress & 4 ? "RPGBICO5" : "RPGBICO4")),"A",BATTLE_ICONS+2,BATTLE_GRID_X,BATTLE_GRID_Y+16.0);

                if (bElphPos == 1 && !(attackProgress & 1)) {attackProgress |= 1; attackStrength += attackBonus; PlaySound(0,"RPGBSEL2",2);}
                if (bElphPos == 4 && !(attackProgress & 2)) {attackProgress |= 2; attackStrength += attackBonus; PlaySound(0,"RPGBSEL2",2);}
                if (bElphPos == 7 && !(attackProgress & 4)) {attackProgress |= 4; attackStrength += attackBonus; PlaySound(0,"RPGBSEL2",2);}
            }

            attackBonusTimer = (attackBonusTimer+1)%3;
            if (attackBonusTimer == 2 && attackStrength > 1) {attackStrength--;}
            if (debugger) {debugMessage3 = strParam(s:"ATKM ",i: attackStrength,s:" ",i:attackProgress);}
            Delay(1);
        }
    }

    attackStrength = (attackStrength * (attackType == bPATK_BOW ? enemyDB[bEnemyType+10] : enemyDB[bEnemyType+11])) + killCount >> 16;

    PlaySound(0,"RPGBSEL3",2);
    b_clearIcons();

    if (bSafetyCheck && vHP > 0) {draw("RPGBTILG","A",BATTLE_GRID, BATTLE_GRID_X, BATTLE_GRID_Y);}
    Delay(2);
    if (bSafetyCheck && vHP > 0) {draw("RPGBTILE","A",BATTLE_GRID, BATTLE_GRID_X, BATTLE_GRID_Y);}

    Delay(4);

	if (attackType == bPATK_MELEE && bSafetyCheck)
	{
		PlaySound(0,"RPGBMEL",3);
		draw("RPGBFX1", "A", BATTLE_FX, BATTLE_GRID_X, BATTLE_GRID_Y-112.0); Delay(2);
		draw("RPGBFX2", "A", BATTLE_FX, BATTLE_GRID_X, BATTLE_GRID_Y-112.0); Delay(3);
		draw("RPGBFX3", "A", BATTLE_FX, BATTLE_GRID_X, BATTLE_GRID_Y-112.0); Delay(4);
	}

	else if (attackType == bPATK_BOW && bSafetyCheck)
	{
		PlaySound(0,"RPGBBOW",3);
		draw("RPGBFX4", "A", BATTLE_FX, BATTLE_GRID_X, BATTLE_GRID_Y-112.0); Delay(2);
		draw("RPGBFX5", "A", BATTLE_FX, BATTLE_GRID_X, BATTLE_GRID_Y-112.0); Delay(2);
		draw("RPGBFX6", "A", BATTLE_FX, BATTLE_GRID_X, BATTLE_GRID_Y-112.0); Delay(3);
		draw("RPGBFX7", "A", BATTLE_FX, BATTLE_GRID_X, BATTLE_GRID_Y-112.0); Delay(4);
	}

	if (bSafetyCheck)
	{
		ACS_NamedTerminate("b_dmgNum",0);
		delay(1);
        if (attackStrength > 0) {ACS_NamedExecute("b_dmgNum",0,attackStrength);}
		bEnemyHP -= attackStrength;
		if (bEnemyHP < 0) {bEnemyHP = 0;}
		b_drawHUD();
		b_ATBreset();
	}

	clear(BATTLE_FX);

	if (bEnemyHP > 0 && bSafetyCheck)
	{
        if (attackStrength > 0)
        {
            ACS_NamedExecute("b_hurtEnemyFeedback",0,attackStrength);
        }
        else {PlaySound(0,"RPGDEFL",4);}
	}
	else
	{
		ACS_NamedExecute("b_win",0);
	}
}

script "b_dmgNum" (int attack, int entity, int lastPos)
{
	bool heal = 0;
	if (lastPos > 9) {lastPos -= 100; heal = 1;}
    setRes();
    SetFont("guwa8-1");
    int moveUp = 1.0;
    for (int i = 1; i < 24; i++)
    {
		if (entity == 0)
		{
			HudMessage(i:attack;HUDMSG_PLAIN|HUDMSG_COLORSTRING,BATTLE_DMGNUM,(i <= 7 ? "Harsh" : (Timer()%2 == 0 && i > 7 ? "HarshPurple" : "HarshRed")),BATTLE_GRID_X, (BATTLE_GRID_Y-144.0)-moveUp,0.1);
		}
		else
		{
			HudMessage(
			i:attack;
			HUDMSG_PLAIN|HUDMSG_COLORSTRING,
			BATTLE_DMGNUM,
			(i <= 7 ? "Harsh" : (heal ? "HarshGreen" : (Timer()%2 == 0 && i > 7 ? "HarshPurple" : "HarshRed"))),
			(BATTLE_GRID_X - 16.0) + ((lastPos % 3) * 16 << 16),
			(BATTLE_GRID_Y - 16.0) + ((lastPos / 3) * 16 << 16)- 24.0 - moveUp,0.1);
		}
        if (i < 8)
        {
            moveUp += (i < 5 ? (i < 2 ? 3.0 : 2.0 ) : 1.0);
            Delay(i < 7 ? (i < 4 ? 1 : 2) : 3);
        }
        else {Delay(1);}
    }
    clear(BATTLE_DMGNUM);
}

script "b_battleMenuMiss" (void)
{
    PlaySound(0,"RPGMISS",4);
    for (int i = 0; i < 4; i++)
    {
        if (bSafetyCheck && vHP > 0) {draw("RPGBTILM","A",BATTLE_GRID, BATTLE_GRID_X, BATTLE_GRID_Y);} Delay(3);
        if (bSafetyCheck && vHP > 0) {draw("RPGBTILE","A",BATTLE_GRID, BATTLE_GRID_X, BATTLE_GRID_Y);} Delay(3);
    }
}

script "b_moveHandler" (void)
{
    while (vHP > 0)
    {
        if (inputUp && bElphPos > 2)
        {
            PlaySound(0,"RPGSTEP",4);
            bElphPos -= 3;
			bMoved = 1;
            getRNG();
        }
        if (inputDown && bElphPos < 6)
        {
            PlaySound(0,"RPGSTEP",4);
            bElphPos += 3;
			bMoved = 1;
            getRNG();
        }
        if (inputLeft && bElphPos % 3 > 0)
        {
            PlaySound(0,"RPGSTEP",4);
            bElphPos -= 1;
			bMoved = 1;
            getRNG();
        }
        if (inputRight && bElphPos % 3 < 2)
        {
            PlaySound(0,"RPGSTEP",4);
            bElphPos += 1;
			bMoved = 1;
            getRNG();
        }
        if (bElphPos < 0) {bElphPos = 0;}
        if (bElphPos > 8) {bElphPos = 8;}
        draw(strParam(s:(bElphHurt && Timer()%2 == 0 ? "RPGELPHD" : "RPGELPHB")), "A", BATTLE_ELPH, (BATTLE_GRID_X - 16.0) + ((bElphPos % 3) * 16 << 16), (BATTLE_GRID_Y - 16.0) + ((bElphPos / 3) * 16 << 16));
        Delay(1);
    }
}

function void drawElphHPmeter (void)
{
    for (int i = 0; i < 40; i++)
	{
		clear(BATTLE_ATBMETER-(i+41));
	}
    setRes();
    SetFont("RPGBUIM");
    for (i = 0; i < vHP; i++)
    {
        HudMessage(s:"A";HUDMSG_PLAIN,BATTLE_ATBMETER-(i+41),CR_UNTRANSLATED,(BATTLE_GRID_X-16.0)+(i<<16),BATTLE_GRID_Y+28.0,0);
    }
}

function void drawATBmeter (void)
{
    setRes();
    SetFont("RPGBUIA");
    for (int i = 0; i < bATBvalue; i++)
    {
        HudMessage(s:"A";HUDMSG_PLAIN,BATTLE_ATBMETER-(i+1),CR_UNTRANSLATED,(BATTLE_GRID_X-16.0)+(i<<16),BATTLE_GRID_Y+35.0,0);
    }
}

script "b_ATB" (void)
{
    while (bATBvalue < 40 && bATBactive)
    {
		if (!bMoved)
        {
            if (altBoss2Clear && vPowerSpeed && Timer()%3 == 2)
            {bATBvalue++;}
            else if (Timer()%5 == 4)
            {bATBvalue++;}
        }
		if (Timer()%5 == 4) {bMoved = 0;}
        if (bATBvalue > 40) {bATBvalue = 40;}
        drawATBmeter();
        Delay(1);
    }
    drawATBmeter();
    bATBactive = 0;
    ACS_NamedExecute("b_battleMenu",0);
}

function void b_ATBreset (void)
{
	for (int i = 0; i < 40; i++)
	{
		clear(BATTLE_ATBMETER-(i+1));
	}
    bATBactive = 1;
    bATBvalue = 0;
    ACS_NamedExecute("b_ATB",0);
}

function int b_dmgRNG (int attack)
{
    int output = attack+getRNG()%5-2;
    return output;
}

script "b_hurtEnemyFeedback" (int attackStrength)
{
    if (bEnemyType != bENEMY_ATLAS)
    {
        bYAmp = attackStrength/2;
        bYFreq = attackStrength*1000;
        bXAmp = attackStrength/3;
        bXFreq = attackStrength*700;
    }
    bEnemyHurt = 1;
    b_enemyAttacking(0);

	ACS_NamedTerminate(strParam(s:"b_attackPatterns",i:bEnemyType),0);
    ACS_NamedTerminate("b_attackSquare",0);
    bSquareKill = 1;
    AmbientSound(enemyDB[bEnemyType+9],127);

    Delay(30);
    bSquareKill = 0;

    bYAmp = enemyDB[bEnemyType+3];
    bYFreq = enemyDB[bEnemyType+4];
    bXAmp = enemyDB[bEnemyType+5];
    bXFreq = enemyDB[bEnemyType+6];
    bXSine = 0;
    bYSine = 0;
    bXOffset = 0;
    bYOffset = 0;
    bEnemyHurt = 0;
	Delay(30);
	if (bSafetyCheck) {ACS_NamedExecute(strParam(s:"b_attackPatterns",i:bEnemyType),0);}
}

function void b_hurtPlayer (int hurtAmount)
{
    vHP -= hurtAmount;
	if (vHP <= 0) {vHP = 0;}
	b_drawHUD();
    if (vHP <= 0)
    {
        ACS_NamedExecute("b_End",0,2);
    }
    else
    {
        if (bSafetyCheck)
		{
		ACS_NamedExecute("b_hurtPlayerFeedback",0, hurtAmount);
		}
    }
}

script "b_hurtPlayerFeedback" (int hurtAmount)
{
    PlaySound(0,"RPGHURT",1);
    bElphHurt = 1;
	ACS_NamedTerminate("b_dmgNum",0);
	delay(1);
	ACS_NamedExecute("b_dmgNum",0,hurtAmount,1, bElphPos);
    Delay(4);
    bElphHurt = 0;
}

script "b_attackSquare" (int squarePos, int attackPower, int holdTime)
{
    if (holdTime > 0) {bool held = 1;}
    if (bSafetyCheck)
    {
        int squarePosX = (BATTLE_GRID_X - 16.0) + ((squarePos % 3) * 16 << 16);
        int squarePosY = (BATTLE_GRID_Y - 16.0) + ((squarePos / 3) * 16 << 16);
        str attackTexture = "";

        AmbientSound(strParam(s:"RPGNOTE",i:squarePos),127);
        for (int i = 0; i < 10; i++)
        {
            if (bSafetyCheck && !bSquareKill)
            {
                attackTexture = strParam(s:(held ? "RPGBWRX" : "RPGBWRN"),i:i);
                draw(attackTexture,"A",BATTLE_SQUARE+squarePos, squarePosX, squarePosY);
                Delay((i < 3 ? (vHardMode >= 0 ? 2 : 1) : (vHardMode < 2 ? 1 : 2)));
            }
        }

        clear(BATTLE_SQUARE+squarePos);

        if (holdTime == 0 && bSafetyCheck && !bSquareKill)
        {
            PlaySound(0,"RPGTARGT",1);
            bATBvalue++;
            if (bATBvalue > 40) {bATBvalue = 40;}
        }

        if (held)
        {
            PlaySound(0,"RPGBALL",2);
            bATBvalue++;
            if (bATBvalue > 40) {bATBvalue = 40;}
        }

        while (holdTime > 0 && bSafetyCheck && !bSquareKill)
        {
            draw("RPGBBOM1","A",BATTLE_SQUARE+squarePos, squarePosX, squarePosY);
            Delay(1);
            draw("RPGBBOM2","A",BATTLE_SQUARE+squarePos, squarePosX, squarePosY);
            Delay(1);
            if (squarePos == bElphPos && !bElphHurt && bSafetyCheck && holdTime > 2) {b_hurtPlayer(2+(getRNG()%3)-vHardMode);}
            holdTime--;
        }

        for (i = 1; i < 3; i++)
        {
            if (bSafetyCheck && !bSquareKill)
            {
                attackTexture = strParam(s:(held ? "RPGBBMX" : "RPGBATK"),i:i);
                draw(attackTexture,"A",BATTLE_SQUARE+squarePos, squarePosX, squarePosY);
                Delay(2);
                if (!held && squarePos == bElphPos && i == 1 && !bElphHurt) {b_hurtPlayer(4+(getRNG()%3)-vHardMode);}
            }
        }
        clear(BATTLE_SQUARE+squarePos);
    }
}

function void b_attackGrid (int attackType)
{
    int thisAttack[9] =
    {
        attackGridDB[attackType+0],
        attackGridDB[attackType+1],
        attackGridDB[attackType+2],
        attackGridDB[attackType+3],
        attackGridDB[attackType+4],
        attackGridDB[attackType+5],
        attackGridDB[attackType+6],
        attackGridDB[attackType+7],
        attackGridDB[attackType+8],
    };
    for (int x = 0; x < 9; x++)
    {
        if (thisAttack[x] > 1)
        {
            ACS_NamedExecuteAlways("b_attackSquare",0,x,0,thisAttack[x]);
        }
        else if (thisAttack[x] == 1)
        {
            ACS_NamedExecuteAlways("b_attackSquare",0,x,0);
        }
    }
}

function void b_attackPass (int squarePos, int holdTime)
{
    ACS_NamedExecuteAlways("b_attackSquare",0,squarePos,0,holdTime);
}

function void b_enemyAttacking (bool attacking)
{
    switch (attacking)
    {
        case 0:
        bEnemyAttacking = 0;
        b_drawHud();
        break;

        case 1:
        bEnemyAttacking = 1;
        b_drawHud();
        break;
    }
}

script "b_attackPatterns0" (void) // VICTIM
{
    b_enemyAttacking(0);
    int short = 7+vHardMode;
    int mid = 20+vHardMode;
    int long = (getRNG()%40+40)+vHardMode;
    int attack = getRNG()%5;
    if (debugger) {debugMessage = strParam(s:"S",i:short,s:" M",i:mid,s:" L",i:long,s:"\n");}

    switch (attack)
    {
        case 0:
            b_enemyAttacking(1);
            b_attackPass(6,0); delay(short);
            b_attackPass(3,0); delay(short);
            b_attackPass(0,0); delay(mid);
            b_attackPass(1,0); delay(short);
            b_attackPass(4,0); delay(short);
            b_attackPass(7,0); delay(mid);
            b_attackPass(8,0); delay(short);
            b_attackPass(5,0); delay(short);
            b_attackPass(2,0);
            break;

        case 1:
            b_enemyAttacking(1);
            b_attackGrid(bATK_COL_L); Delay(mid);
            b_attackGrid(bATK_COL_M); Delay(mid);
            b_attackGrid(bATK_COL_R);
            break;

        case 2:
            b_enemyAttacking(1);
            b_attackGrid(bATK_COL_R); Delay(mid);
            b_attackGrid(bATK_COL_M); Delay(mid);
            b_attackGrid(bATK_COL_L);
            break;

        case 3:
            b_enemyAttacking(1);
            b_attackGrid(bATK_ROW_U); Delay(mid);
            b_attackGrid(bATK_ROW_M); Delay(mid);
            b_attackGrid(bATK_ROW_B);
            break;

        case 4:
            b_enemyAttacking(1);
            b_attackGrid(bATK_ROW_B); Delay(mid);
            b_attackGrid(bATK_ROW_M); Delay(mid);
            b_attackGrid(bATK_ROW_U);
            break;
    }
    b_enemyAttacking(0);
	Delay(long);
    Restart;
}

script "b_attackPatterns12" (void) // CHICKEN
{
    b_enemyAttacking(0);
    int short = 4+vHardMode;
    int mid = 15+vHardMode;
    int long = (getRNG()%30+30+vHardMode);
    int attack = getRNG()%4;
    if (debugger) {debugMessage = strParam(s:"S",i:short,s:" M",i:mid,s:" L",i:long,s:"\n");}

    switch (attack)
    {
        case 0:
            b_enemyAttacking(1);
            b_attackPass(2,0); delay(short);
            b_attackPass(4,0); delay(short);
            b_attackPass(6,0); delay(short);
            Delay(mid+getRNG()%11);
            b_attackPass(0,0); delay(short);
            b_attackPass(4,0); delay(short);
            b_attackPass(8,0);
            break;

        case 1:
            b_enemyAttacking(1);
            b_attackGrid(bATK_SLASH_F); Delay(mid);
            b_attackGrid(bATK_COL_M); Delay(mid);
            b_attackGrid(bATK_SLASH_B); Delay(mid);
            b_attackGrid(bATK_ROW_M); Delay(mid);
            b_attackGrid(bATK_SLASH_F); Delay(mid);
            b_attackGrid(bATK_COL_M); Delay(mid);
            b_attackGrid(bATK_SLASH_B); Delay(mid);
            b_attackGrid(bATK_ROW_M);
            break;

        case 2:
            b_enemyAttacking(1);
            b_attackGrid(bATK_SLASH_B); Delay(mid);
            b_attackGrid(bATK_COL_M); Delay(mid);
            b_attackGrid(bATK_SLASH_F); Delay(mid);
            b_attackGrid(bATK_ROW_M); Delay(mid);
            b_attackGrid(bATK_SLASH_B); Delay(mid);
            b_attackGrid(bATK_COL_M); Delay(mid);
            b_attackGrid(bATK_SLASH_F); Delay(mid);
            b_attackGrid(bATK_ROW_M);
            break;

        case 3:
            b_enemyAttacking(1);
            for (int i = 0; i < getRNG()%2+3; i++)
            {
                b_attackGrid(bATK_COL_M); Delay(mid);
                b_attackGrid(bATK_COL_L);
                b_attackGrid(bATK_COL_R); Delay(mid+getRNG()%10+10);
            }
        break;
    }
    b_enemyAttacking(0);
    Delay(long);
    Restart;
}

script "b_attackPatterns24" (void) // PRAYER && SHADOW
{
    b_enemyAttacking(0);
    int short = 4+vHardMode;
    int mid = 13+vHardMode;
    int long = getRNG()%30+40+vHardMode;
    int attack = getRNG()%4;
    if (debugger) {debugMessage = strParam(s:"S",i:short,s:" M",i:mid,s:" L",i:long,s:"\n");}

    switch (getRNG()%4)
    {
        case 0:
            b_enemyAttacking(1);
            b_attackPass(2,45);
            b_attackPass(5,45);
            b_attackPass(8,45);
            delay(mid);
            break;

        case 1:
            b_enemyAttacking(1);
            b_attackPass(0,45);
            b_attackPass(3,45);
            b_attackPass(6,45);
            delay(mid);
            break;

        case 2:
            b_enemyAttacking(1);
            b_attackPass(0,45);
            b_attackPass(2,45);
            b_attackPass(6,45);
            b_attackPass(8,45);
            delay(mid);
