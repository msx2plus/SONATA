            b_attackPass(3,0); b_attackPass(4,0); Delay(short);
            b_attackPass(6,0); b_attackPass(7,0); Delay(mid);
            b_attackPass(1,0); b_attackPass(2,0); Delay(short);
            b_attackPass(4,0); b_attackPass(5,0); Delay(short);
            b_attackPass(7,0); b_attackPass(8,0);
